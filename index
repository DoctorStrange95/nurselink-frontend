function ts() {
  return new Date().toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) + ' ' +
         new Date().toLocaleDateString('en-IN',{day:'2-digit',month:'2-digit'});
}

function getRole() { return S.currentRole; }
function getStaff(role) { return S.staff.find(s => s.role === role) || S.staff[0]; }
function getCurrentStaffName() {
  if (IS_LIVE && window._loggedInUser) return window._loggedInUser.name;
  const m = { Doctor:'Dr. Arjun Mehta', Nurse:'Priya Sharma', Pharmacist:'Raj Dispensary', 'Lab Tech':'Anand Kumar', Admin:'Vikram Singh' };
  return m[getRole()] || 'Staff';
}

function vitalStatus(v) {
  if (!v) return 'normal';
  if (v.bpSys > 180 || v.bpSys < 90 || v.spo2 < 92 || v.pulse > 130 || v.pulse < 50 || v.temp > 39.5) return 'critical';
  if (v.bpSys > 160 || v.bpSys < 100 || v.spo2 < 95 || v.pulse > 110 || v.temp > 38.5 || v.rr > 25) return 'warning';
  return 'normal';
}

function checkAlerts(patientId, vital) {
  const p = S.patients.find(x => x.id === patientId);
  const alerts = [];
  if (vital.bpSys > 180) alerts.push({ type:'critical', title:'BP CRITICAL', msg:`BP ${vital.bpSys}/${vital.bpDia} — Hypertensive Emergency` });
  else if (vital.bpSys > 160) alerts.push({ type:'warning', title:'BP HIGH', msg:`BP ${vital.bpSys}/${vital.bpDia} — Elevated` });
  if (vital.bpSys < 90) alerts.push({ type:'critical', title:'HYPOTENSION', msg:`BP ${vital.bpSys}/${vital.bpDia} — Check for shock` });
  if (vital.spo2 < 92) alerts.push({ type:'critical', title:'SpO2 CRITICAL', msg:`SpO2 ${vital.spo2}% — Severe hypoxia` });
  else if (vital.spo2 < 95) alerts.push({ type:'warning', title:'SpO2 LOW', msg:`SpO2 ${vital.spo2}% — Below normal` });
  if (vital.pulse > 130) alerts.push({ type:'critical', title:'TACHYCARDIA', msg:`Pulse ${vital.pulse} bpm — Severe` });
  if (vital.pulse < 50) alerts.push({ type:'critical', title:'BRADYCARDIA', msg:`Pulse ${vital.pulse} bpm` });
  if (vital.temp > 39.5) alerts.push({ type:'critical', title:'HIGH FEVER', msg:`Temp ${vital.temp}°C — Hyperpyrexia` });
  else if (vital.temp > 38.5) alerts.push({ type:'warning', title:'FEVER', msg:`Temp ${vital.temp}°C` });
  if (vital.uo < 20) alerts.push({ type:'warning', title:'OLIGURIA', msg:`Urine Output ${vital.uo} ml/hr — Low` });
  if (vital.rr > 25) alerts.push({ type:'warning', title:'TACHYPNEA', msg:`RR ${vital.rr}/min — High` });
  alerts.forEach(a => {
    S.alerts.unshift({ id:'A'+Date.now()+Math.random(), patientId, type:a.type, title:a.title, msg:a.msg, time:ts(), acked:false });
    showToast(`${a.title}: ${p.name}`, a.type === 'critical' ? 'error' : 'warn');
    // push notification to doctor
    S.notifications.unshift({ id:'N'+Date.now(), role:'Doctor', title:`⚠ ${a.title}`, body:`${p.name} — ${a.msg}`, time:ts(), read:false });
  });
}

function showToast(msg, type='info') {
  const tc = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.textContent = msg;
  tc.appendChild(t);
  setTimeout(() => t.remove(), 4000);
}

function showModal(html) {
  const mc = document.getElementById('modal-container');
  mc.innerHTML = `<div class="modal-overlay" onclick="if(event.target===this)closeModal()">${html}</div>`;
}

function closeModal() {
  document.getElementById('modal-container').innerHTML = '';
}

function showPayload(data) {
  showModal(`<div class="modal">
    <div class="modal-header"><h2>📡 Integration Payload</h2><button class="modal-close" onclick="closeModal()">×</button></div>
    <div class="modal-body">
      <p class="text-muted mb-2">This JSON would be sent to any connected EHR via webhook:</p>
      <div class="payload-code">${JSON.stringify({...data, integration_version:'v1.0', source_system:'NurseLink IPD', timestamp:new Date().toISOString()}, null, 2)}</div>
    </div>
    <div class="modal-footer"><button class="btn btn-outline btn-sm" onclick="closeModal()">Close</button></div>
  </div>`);
}

