async function submitConsult(pid) {
  const subj = document.getElementById('c-subj').value.trim();
  const obj = document.getElementById('c-obj').value.trim();
  const assess = document.getElementById('c-assess').value.trim();
  const plan = document.getElementById('c-plan').value.trim();
  if (!subj || !assess) { alert('Subjective and Assessment are required.'); return; }
  if (!S.consultNotes[pid]) S.consultNotes[pid] = [];
  const note = { id:'C'+Date.now(), time:now(), by:getCurrentStaffName(), subjective:subj, objective:obj, assessment:assess, plan };
  S.consultNotes[pid].unshift(note);
  S.notifications.unshift({ id:'N'+Date.now(), role:'Nurse', title:'New Consultation', body:`${S.patients.find(p=>p.id===pid)?.name} — Note added`, time:ts(), read:false });
  closeModal();

  if (IS_LIVE) {
    const res = await apiPost('/notes/consult/' + pid, { subjective:subj, objective:obj, assessment:assess, plan });
    showToast(res ? 'Consultation note saved ✓' : 'Saved locally — server sync failed', res ? 'info' : 'warn');
  } else { showToast('Consultation note saved'); }
  showPayload({ event:'CONSULT_NOTE_ADDED', patient_ehr_id:S.patients.find(p=>p.id===pid)?.ehrId, note });
  save();
}

