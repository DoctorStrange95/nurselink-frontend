<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NurseLink IPD</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --navy:#0A1628;--navy2:#112240;--navy3:#1a2f50;
  --teal:#00C4B4;--teal2:#009e91;--teal3:#e0faf8;
  --indigo:#5C6BC0;--emerald:#2E7D32;--amber:#E65100;
  --red:#C62828;--red2:#ffebee;
  --slate:#546E7A;--panel:#F0F4F8;--white:#fff;
  --text:#1A2332;--muted:#64748B;--border:#CBD5E1;
  --shadow:0 2px 12px rgba(0,0,0,.08);--shadowlg:0 8px 32px rgba(0,0,0,.14);
  --font:'DM Sans',sans-serif;--mono:'IBM Plex Mono',monospace;
  --rc:var(--teal);
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font);background:var(--panel);color:var(--text);min-height:100vh;font-size:14px}
::-webkit-scrollbar{width:5px;height:5px}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

/* LOGIN */
#ls{position:fixed;inset:0;background:var(--navy);display:flex;align-items:center;justify-content:center;z-index:900}
.lb{background:white;border-radius:16px;padding:40px;width:420px;box-shadow:0 24px 64px rgba(0,0,0,.5)}
.lb-logo{font-size:26px;font-weight:800;color:var(--navy);letter-spacing:-1px;margin-bottom:4px}
.lb-logo em{color:var(--teal);font-style:normal;font-weight:300}
.lb-sub{font-size:13px;color:var(--muted);margin-bottom:28px}
.lb-err{display:none;background:var(--red2);color:var(--red);border-left:3px solid var(--red);padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:14px}
.lb-hint{margin-top:16px;font-size:11px;color:var(--muted);line-height:1.6}

/* TOPBAR */
#tb{background:var(--navy);color:white;display:flex;align-items:center;padding:0 18px;height:54px;position:sticky;top:0;z-index:100;gap:14px;box-shadow:0 2px 16px rgba(0,0,0,.3);display:none}
.tb-logo{font-size:17px;font-weight:800;color:var(--teal);flex:1;letter-spacing:-.5px}
.tb-logo span{color:rgba(255,255,255,.5);font-weight:300}
#tb-user{font-size:12px;color:rgba(255,255,255,.7);background:rgba(255,255,255,.1);padding:4px 12px;border-radius:20px}
#notif-btn{background:none;border:none;color:white;cursor:pointer;position:relative;font-size:17px;padding:4px 8px}
#nb{position:absolute;top:-2px;right:-2px;background:var(--red);color:white;font-size:9px;font-weight:700;border-radius:10px;padding:1px 5px;display:none}
#tb-clock{font-family:var(--mono);font-size:11px;color:rgba(255,255,255,.4)}
.tb-signout{background:none;border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.6);padding:4px 12px;border-radius:20px;cursor:pointer;font-size:11px;font-family:var(--font)}
#live-dot{width:7px;height:7px;border-radius:50%;background:#4caf50;box-shadow:0 0 6px #4caf50;flex-shrink:0}

/* LAYOUT */
#app{display:flex;height:calc(100vh - 54px);display:none}
#sb{width:214px;background:var(--navy2);color:white;display:flex;flex-direction:column;padding:12px 0;flex-shrink:0}
.sb-sec{font-size:9px;font-weight:700;color:rgba(255,255,255,.25);padding:14px 18px 5px;letter-spacing:1.2px;text-transform:uppercase}
.sb-item{display:flex;align-items:center;gap:10px;padding:9px 18px;cursor:pointer;font-size:13px;font-weight:500;color:rgba(255,255,255,.55);transition:all .12s;border-left:3px solid transparent}
.sb-item:hover{color:white;background:rgba(255,255,255,.05)}
.sb-item.on{color:white;background:rgba(0,196,180,.15);border-left-color:var(--teal);font-weight:600}
.sb-user{margin-top:auto;padding:14px 18px;border-top:1px solid rgba(255,255,255,.07)}
.sb-name{font-size:13px;font-weight:600}
.sb-role{font-size:11px;margin-top:2px}

#main{flex:1;overflow-y:auto;padding:22px}
#rp{width:274px;background:white;border-left:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
.rp-hdr{padding:14px 16px;border-bottom:1px solid var(--border);font-weight:600;font-size:13px;display:flex;align-items:center;justify-content:space-between}
#af{flex:1;overflow-y:auto;padding:8px}

/* CARDS */
.card{background:white;border-radius:10px;box-shadow:var(--shadow);overflow:hidden;margin-bottom:14px}
.ch{padding:13px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.ch h3{font-size:13px;font-weight:600}
.cb{padding:16px}

/* PATIENT CARD */
.pc{background:white;border-radius:10px;box-shadow:var(--shadow);border:1px solid var(--border);overflow:hidden;cursor:pointer;transition:all .14s}
.pc:hover{box-shadow:var(--shadowlg);transform:translateY(-2px)}
.pct{padding:12px 16px;color:white}
.pc-name{font-weight:700;font-size:15px}
.pc-meta{font-size:11px;color:rgba(255,255,255,.65);margin-top:2px}
.pcb{padding:12px 16px}
.pir{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:4px}
.pir b{font-weight:600;color:var(--text)}
.vp{display:inline-flex;align-items:center;background:var(--panel);border-radius:20px;padding:2px 8px;font-size:11px;font-family:var(--mono);margin:2px}
.vp.w{background:#fff3e0;color:var(--amber)}
.vp.c{background:var(--red2);color:var(--red);font-weight:700}

/* VITALS GRID */
.vg{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.vb{background:var(--panel);border-radius:8px;padding:12px;text-align:center;border:1.5px solid transparent}
.vb.cv{background:var(--red2);border-color:var(--red)}
.vb.wv{background:#fff3e0;border-color:var(--amber)}
.vbl{font-size:9px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
.vbv{font-size:20px;font-weight:800;font-family:var(--mono);margin-top:4px;line-height:1}
.vbu{font-size:10px;color:var(--muted);margin-top:2px}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:7px;font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all .12s;font-family:var(--font)}
.btn-p{background:var(--teal);color:white}.btn-p:hover{background:var(--teal2)}
.btn-d{background:var(--red);color:white}
.btn-o{background:transparent;border:1.5px solid var(--border);color:var(--text)}.btn-o:hover{border-color:var(--teal);color:var(--teal)}
.btn-w{background:var(--amber);color:white}
.btn-s{background:var(--emerald);color:white}
.btn-g{background:rgba(255,255,255,.12);color:white;border:1px solid rgba(255,255,255,.2)}
.btn-sm{padding:5px 10px;font-size:12px}
.btn-xs{padding:3px 8px;font-size:11px}

/* BADGE */
.badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px}
.bt{background:var(--teal3);color:#007a72}
.br{background:var(--red2);color:var(--red)}
.bg{background:#e8f5e9;color:var(--emerald)}
.ba{background:#fff3e0;color:var(--amber)}
.bi{background:#e8eaf6;color:var(--indigo)}

/* TABS */
.tabs{display:flex;border-bottom:2px solid var(--border);margin-bottom:18px;gap:2px;overflow-x:auto}
.tab{padding:8px 14px;font-size:13px;font-weight:500;cursor:pointer;color:var(--muted);border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .12s;white-space:nowrap}
.tab.on{color:var(--teal);border-bottom-color:var(--teal);font-weight:700}

/* FORMS */
.fg{margin-bottom:13px}
.fl{display:block;font-size:10px;font-weight:700;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px}
.fc{width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:7px;font-size:13px;font-family:var(--font);transition:border-color .12s;background:white}
.fc:focus{outline:none;border-color:var(--teal)}
.fr2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fr3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.fr4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px}

/* TABLE */
.dt{width:100%;border-collapse:collapse;font-size:12px}
.dt th{background:var(--panel);padding:7px 12px;text-align:left;font-weight:700;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
.dt td{padding:8px 12px;border-bottom:1px solid var(--border);vertical-align:middle}
.dt tr:last-child td{border-bottom:none}
.dt tr:hover td{background:var(--panel)}
.mono{font-family:var(--mono);font-size:12px}
.cv-t{color:var(--red);font-weight:700}
.wv-t{color:var(--amber);font-weight:700}
.ok-t{color:var(--emerald)}

/* MODAL */
.mo{position:fixed;inset:0;background:rgba(10,22,40,.78);z-index:200;display:flex;align-items:center;justify-content:center;padding:16px}
.md{background:white;border-radius:12px;max-width:640px;width:100%;max-height:88vh;overflow-y:auto;box-shadow:var(--shadowlg)}
.md-lg{max-width:760px}
.md-xl{max-width:900px}
.mh{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:white;z-index:10}
.mh h2{font-size:15px;font-weight:700}
.mc{padding:20px}
.mf{padding:14px 20px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px;position:sticky;bottom:0;background:white}
.mclose{background:none;border:none;font-size:20px;cursor:pointer;color:var(--muted);line-height:1;padding:2px 6px}

/* SOS */
#sos{position:fixed;inset:0;background:var(--red);z-index:999;display:none;flex-direction:column;align-items:center;justify-content:center;color:white;text-align:center;animation:pulsb 1.2s infinite}
@keyframes pulsb{0%,100%{background:#c62828}50%{background:#b71c1c}}
.sos-t{font-size:56px;font-weight:900;letter-spacing:-2px}
.sos-p{font-size:22px;margin-top:8px;opacity:.9}
.sos-d{font-family:var(--mono);font-size:13px;margin-top:14px;opacity:.75;line-height:1.8;white-space:pre}

/* ALERT ITEMS */
.ai{padding:10px;border-radius:8px;margin-bottom:8px;font-size:12px;border-left:3px solid}
.ai.critical{background:#ffebee;border-color:var(--red)}
.ai.warning{background:#fff3e0;border-color:var(--amber)}
.ai.info{background:#e3f2fd;border-color:#1976d2}
.ai-t{font-weight:700;font-size:12px}
.ai-m{color:var(--muted);margin-top:2px;font-size:11px}

/* MAR */
.mr{display:flex;align-items:center;gap:10px;padding:10px;border:1px solid var(--border);border-radius:8px;margin-bottom:8px;flex-wrap:wrap}
.mr-drug{flex:1;min-width:130px}
.mr-dn{font-weight:600;font-size:13px}
.mr-dd{font-size:11px;color:var(--muted);font-family:var(--mono)}
.mr-log{font-size:10px;color:var(--muted);font-family:var(--mono);margin-top:3px}
.mb{padding:4px 10px;font-size:11px;font-weight:600;border-radius:5px;border:1.5px solid;cursor:pointer;font-family:var(--font);transition:all .1s}
.mb.gv{border-color:var(--emerald);color:var(--emerald);background:white}.mb.gv.on,.mb.gv:hover{background:var(--emerald);color:white}
.mb.hl{border-color:var(--amber);color:var(--amber);background:white}.mb.hl:hover{background:var(--amber);color:white}
.mb.rf{border-color:var(--slate);color:var(--slate);background:white}.mb.rf:hover{background:var(--slate);color:white}
.mb.na{border-color:var(--red);color:var(--red);background:white}.mb.na.on,.mb.na:hover{background:var(--red);color:white}

/* CHAT */
.ca{height:240px;overflow-y:auto;padding:10px;background:var(--panel);border-radius:8px;margin-bottom:10px}
.cm{margin-bottom:10px}
.cm.s{text-align:right}
.cb2{display:inline-block;padding:8px 12px;border-radius:12px;font-size:12px;max-width:84%;text-align:left}
.cm.r .cb2{background:white;border:1px solid var(--border)}
.cm.s .cb2{background:var(--teal);color:white}
.cm-meta{font-size:10px;color:var(--muted);margin-top:2px}

/* VITALS TREND */
.vt{display:flex;align-items:flex-end;gap:3px;height:38px;padding:4px;background:var(--panel);border-radius:6px}
.vt-b{width:8px;border-radius:2px 2px 0 0;min-height:4px}

/* WORKLOAD */
.wb{height:7px;background:var(--panel);border-radius:4px;overflow:hidden;margin-top:4px}
.wf{height:100%;background:var(--teal);border-radius:4px;transition:width .3s}
.wf.hi{background:var(--red)}
.wf.me{background:var(--amber)}

/* TOAST */
#tc{position:fixed;top:68px;right:14px;z-index:300;display:flex;flex-direction:column;gap:8px}
.toast{background:var(--navy);color:white;padding:11px 16px;border-radius:8px;font-size:13px;box-shadow:var(--shadowlg);max-width:290px;border-left:4px solid var(--teal);animation:sli .3s ease}
.toast.err{border-left-color:var(--red)}
.toast.wrn{border-left-color:var(--amber)}
@keyframes sli{from{transform:translateX(310px);opacity:0}to{transform:translateX(0);opacity:1}}

/* NOTIF DROPDOWN */
#nd{position:fixed;top:54px;right:0;width:300px;background:white;border:1px solid var(--border);border-radius:0 0 10px 10px;box-shadow:var(--shadowlg);z-index:150;max-height:380px;overflow-y:auto;display:none}
.ni{padding:11px 16px;border-bottom:1px solid var(--border);font-size:12px;cursor:pointer}
.ni:hover{background:var(--panel)}
.ni-t{font-weight:700}.ni-b{color:var(--muted);margin-top:2px}.ni-tm{font-size:10px;color:var(--muted);font-family:var(--mono);margin-top:2px}

/* SECTION */
.st{font-size:20px;font-weight:700;color:var(--navy);margin-bottom:5px}
.ss{font-size:13px;color:var(--muted);margin-bottom:18px}
.pg{display:grid;grid-template-columns:repeat(auto-fill,minmax(272px,1fr));gap:14px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}
.flex{display:flex}.ic{align-items:center}.jb{justify-content:space-between}
.g2x{gap:8px}.g3x{gap:12px}
.mt2{margin-top:8px}.mt4{margin-top:16px}.mb2{margin-bottom:8px}.mb4{margin-bottom:16px}
.fw6{font-weight:600}.fs12{font-size:12px}.fs11{font-size:11px}
.tm{color:var(--muted);font-size:12px}
hr.d{border:none;border-top:1px solid var(--border);margin:14px 0}

/* PRESCRIPTION PANEL */
.rx-panel{background:var(--panel);border-radius:10px;padding:14px;margin-bottom:10px}
.rx-row{display:flex;align-items:center;gap:10px;padding:9px 12px;background:white;border-radius:8px;border:1px solid var(--border);margin-bottom:7px}
.rx-drug{font-weight:700;font-size:13px}
.rx-meta{font-size:11px;color:var(--muted);font-family:var(--mono)}
.chip{display:inline-block;background:white;border:1px solid var(--border);border-radius:20px;padding:3px 11px;font-size:11px;margin:2px;cursor:pointer;font-family:var(--font);transition:all .1s}
.chip:hover{border-color:var(--teal);color:var(--teal);background:var(--teal3)}
.chip.sel{background:var(--teal);color:white;border-color:var(--teal)}

/* SUGGEST */
.sg{position:absolute;top:100%;left:0;right:0;background:white;border:1px solid var(--border);border-radius:8px;box-shadow:var(--shadowlg);z-index:50;display:none;max-height:200px;overflow-y:auto}
.sg-i{padding:9px 14px;font-size:13px;cursor:pointer;border-bottom:1px solid var(--border)}
.sg-i:hover{background:var(--panel)}

/* TOGGLE */
.tg{position:relative;width:40px;height:22px;flex-shrink:0}
.tg input{opacity:0;width:0;height:0;position:absolute}
.tg-s{position:absolute;inset:0;background:#cbd5e1;border-radius:22px;cursor:pointer;transition:.2s}
.tg-s:before{content:'';position:absolute;height:16px;width:16px;left:3px;bottom:3px;background:white;border-radius:50%;transition:.2s}
.tg input:checked+.tg-s{background:var(--teal)}
.tg input:checked+.tg-s:before{transform:translateX(18px)}

/* DISCHARGE */
.ds-sec{border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:8px}
.ds-hdr{display:flex;align-items:center;justify-content:space-between;padding:9px 14px;background:var(--panel);font-size:13px;font-weight:600}
.ds-body{padding:12px 14px;font-size:12px;line-height:1.7}

@media(max-width:900px){
  #sb,#rp{display:none}
  .vg,.fr2,.fr3,.fr4,.g2,.g3{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="ls">
  <div class="lb">
    <div class="lb-logo">NurseLink<em> IPD</em></div>
    <div class="lb-sub">Clinical Coordination System — Sign in to continue</div>
    <div class="lb-err" id="le"></div>
    <div class="fg"><label class="fl">Email</label><input class="fc" id="li-e" type="email" value="arjun@nurselink.in"></div>
    <div class="fg"><label class="fl">Password</label><input class="fc" id="li-p" type="password" value="password123" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <button class="btn btn-p" style="width:100%;justify-content:center;padding:11px;font-size:14px" onclick="doLogin()" id="li-btn">Sign In</button>
    <button onclick="demoMode()" style="display:block;width:100%;margin-top:10px;background:none;border:1.5px solid var(--border);border-radius:8px;padding:9px;font-size:13px;cursor:pointer;color:var(--muted);font-family:var(--font)">Continue in Demo Mode</button>
    <div class="lb-hint">
      arjun@nurselink.in (Doctor) · priya@nurselink.in (Nurse)<br>
      raj@nurselink.in (Pharmacist) · anand@nurselink.in (Lab Tech)<br>
      vikram@nurselink.in (Admin) — all use <b>password123</b>
    </div>
  </div>
</div>

<!-- TOPBAR -->
<div id="tb">
  <div class="tb-logo">NurseLink<span> IPD</span></div>
  <div id="live-dot" title="Live"></div>
  <span id="tb-user"></span>
  <button id="notif-btn" onclick="toggleNotif()">🔔<span id="nb">0</span></button>
  <div id="tb-clock"></div>
  <button class="tb-signout" onclick="doLogout()">Sign Out</button>
</div>
<div id="nd"></div>

<!-- APP -->
<div id="app">
  <div id="sb"></div>
  <div id="main"><div style="padding:40px;color:var(--muted)">Loading…</div></div>
  <div id="rp">
    <div class="rp-hdr">
      <span>⚡ Alerts</span>
      <span id="ac" class="badge br" style="display:none">0</span>
    </div>
    <div id="af"></div>
  </div>
</div>

<!-- SOS -->
<div id="sos">
  <div class="sos-t">🚨 SOS</div>
  <div class="sos-p" id="sos-pn"></div>
  <div class="sos-d" id="sos-d"></div>
  <button class="btn btn-g" style="margin-top:20px;font-size:15px;padding:13px 32px" onclick="ackSOS()">✔ ACKNOWLEDGE (Doctor Only)</button>
  <div style="margin-top:10px;font-size:11px;opacity:.5" id="sos-note"></div>
</div>

<!-- MODAL / TOAST -->
<div id="mc"></div>
<div id="tc"></div>

<script>
// ═══════════════════════════════════════════════
// API
// ═══════════════════════════════════════════════
const API = 'https://nurselink-server.onrender.com/api';
let TOKEN = null, IS_LIVE = false, USER = null;

async function apig(path){
  if(!TOKEN) return null;
  try{const r=await fetch(API+path,{headers:{Authorization:'Bearer '+TOKEN}});return r.ok?await r.json():null}catch{return null}
}
async function apip(path,body){
  if(!TOKEN) return null;
  try{const r=await fetch(API+path,{method:'POST',headers:{'Content-Type':'application/json',Authorization:'Bearer '+TOKEN},body:JSON.stringify(body)});return r.ok?await r.json():null}catch{return null}
}
async function apipa(path,body){
  if(!TOKEN) return null;
  try{const r=await fetch(API+path,{method:'PATCH',headers:{'Content-Type':'application/json',Authorization:'Bearer '+TOKEN},body:JSON.stringify(body)});return r.ok?await r.json():null}catch{return null}
}

// ═══════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════
const NOW=()=>new Date().toLocaleDateString('en-IN')+' '+new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
const TS=()=>new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})+' '+new Date().toLocaleDateString('en-IN',{day:'2-digit',month:'2-digit'});

const DEMO={
  role:'Doctor',nav:'',pid:null,tab:'overview',
  staff:[
