        <div style="width:36px;height:36px;border-radius:50%;background:${roleColors[s.role]||'var(--slate)'};display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:13px;flex-shrink:0">${s.name.split(' ').map(n=>n[0]).join('').slice(0,2)}</div>
        <div style="flex:1"><div class="fw6 fs12">${s.name}</div><div class="tm fs11">${s.role} · ${s.dept}</div></div>
        <span class="badge bt">${s.role}</span>
      </div>`).join('')}
    </div></div>
  `;
}

function showAddStaff(){
  showModal(`<div class="md">
    <div class="mh"><h2>Add Staff</h2><button class="mclose" onclick="closeModal()">×</button></div>
    <div class="mc">
      <div class="fr2"><div class="fg"><label class="fl">Name *</label><input class="fc" id="sfn"></div><div class="fg"><label class="fl">Role</label><select class="fc" id="sfr"><option>Doctor</option><option>Nurse</option><option>Pharmacist</option><option>Lab Tech</option><option>Admin</option></select></div></div>
      <div class="fr2"><div class="fg"><label class="fl">Department</label><input class="fc" id="sfd"></div><div class="fg"><label class="fl">Employee ID</label><input class="fc" id="sfe"></div></div>
    </div>
    <div class="mf"><button class="btn btn-o" onclick="closeModal()">Cancel</button><button class="btn btn-p" onclick="submitAddStaff()">Add</button></div>
  </div>`);
}

function submitAddStaff(){
  const name=document.getElementById('sfn').value.trim();
  if(!name){alert('Name required');return;}
  S.staff.push({id:'S'+Date.now(),name,role:document.getElementById('sfr').value,dept:document.getElementById('sfd').value||'General',emp:document.getElementById('sfe').value||'',color:'#546E7A'});
  closeModal(); showToast(`${name} added`); save();
}

function renderBeds(){
  const main=document.getElementById('main');
  const wards=[...new Set(S.beds.map(b=>b.ward))];
  main.innerHTML=`<div class="st mb4">Bed Management</div><div class="ss">${S.beds.filter(b=>b.status==='available').length} of ${S.beds.length} available</div>`+
    wards.map(w=>`<div class="fw6 mb2 mt4">Ward ${w}</div><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:10px">
      ${S.beds.filter(b=>b.ward===w).map(b=>{const pt=S.patients.find(p=>p.bed===b.id&&p.status==='Active');return `<div style="background:${b.status==='available'?'#e8f5e9':'var(--red2)'};border:1.5px solid ${b.status==='available'?'var(--emerald)':'var(--red)'};border-radius:8px;padding:12px;text-align:center">
        <div style="font-size:15px;font-weight:700">${b.id}</div>
        <div style="font-size:10px;font-weight:700;color:${b.status==='available'?'var(--emerald)':'var(--red)'}">${b.status.toUpperCase()}</div>
        ${pt?`<div style="font-size:10px;color:var(--muted);margin-top:3px">${pt.name}</div>`:''}
      </div>`;}).join('')}
    </div>`).join('');
}

function renderWorkload(){
  const main=document.getElementById('main');
  const drs=S.staff.filter(s=>s.role==='Doctor');
  const nrs=S.staff.filter(s=>s.role==='Nurse');
  main.innerHTML=`
    <div class="st mb4">Workload</div>
    <div class="g2">
      <div class="card"><div class="ch"><h3>Doctors</h3></div><div class="cb">
        ${drs.map(d=>{const c=S.patients.filter(p=>p.doc===d.id&&p.status==='Active').length;const pct=Math.min(Math.round((c/10)*100),100);return `<div class="mb4"><div class="flex ic jb mb2"><span class="fw6 fs12">${d.name}</span><span class="tm fs12">${c} pts</span></div><div class="wb"><div class="wf ${c>=8?'hi':c>=5?'me':''}" style="width:${pct}%"></div></div></div>`;}).join('')}
      </div></div>
      <div class="card"><div class="ch"><h3>Nurses</h3></div><div class="cb">
        ${nrs.map(n=>{const c=S.patients.filter(p=>p.nurse===n.id&&p.status==='Active').length;const pct=Math.min(Math.round((c/5)*100),100);return `<div class="mb4"><div class="flex ic jb mb2"><span class="fw6 fs12">${n.name}</span><span class="tm fs12">${c}/5 pts</span></div><div class="wb"><div class="wf ${c>=4?'hi':c>=3?'me':''}" style="width:${pct}%"></div></div></div>`;}).join('')}
      </div></div>
    </div>
  `;
}

// ═══════════════════════════════════════════════
// TOAST & CLOCK
// ═══════════════════════════════════════════════
function showToast(msg,type=''){
  const tc=document.getElementById('tc');
  const t=document.createElement('div');
  t.className='toast '+(type);
  t.textContent=msg; tc.appendChild(t);
  setTimeout(()=>t.remove(),4000);
}

setInterval(()=>document.getElementById('tb-clock').textContent=new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:true})+' IST',1000);

// ═══════════════════════════════════════════════
// AUTO-LOGIN FROM SAVED TOKEN
// ═══════════════════════════════════════════════
(async()=>{
  const tok=localStorage.getItem('nl_tok');
  const usr=localStorage.getItem('nl_usr');
  if(tok&&usr){
    TOKEN=tok; USER=JSON.parse(usr);
    const rm={Doctor:'Doctor',Nurse:'Nurse',Pharmacist:'Pharmacist','Lab Tech':'Lab Tech',Admin:'Admin'};
    S.role=rm[USER.role]||S.role;
    IS_LIVE=true;
    const ok=await apig('/patients');
    if(ok){await syncLiveData();startApp();}
    else{TOKEN=null;USER=null;IS_LIVE=false;localStorage.removeItem('nl_tok');localStorage.removeItem('nl_usr');}
  }
})();
</script>
