function calcLOS(admitTime) {
  if (!admitTime) return 0;
  try {
    // Handle DD/MM/YYYY HH:MM format
    const parts = admitTime.split(' ');
    const dateParts = parts[0].split('/');
    if (dateParts.length === 3) {
      const d = new Date(
        parseInt(dateParts[2]),
        parseInt(dateParts[1]) - 1,
        parseInt(dateParts[0])
      );
      if (!isNaN(d.getTime())) {
        return Math.max(0, Math.round((Date.now() - d.getTime()) / (1000*60*60*24)));
      }
    }
    // Fallback: try direct parse
    const d2 = new Date(admitTime);
    if (!isNaN(d2.getTime())) {
      return Math.max(0, Math.round((Date.now() - d2.getTime()) / (1000*60*60*24)));
    }
  } catch(e) {}
  return 0;
}

