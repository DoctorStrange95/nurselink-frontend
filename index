async function submitAdmit() {
  const isIPD = document.getElementById('admit-mode-toggle')?.checked || false;
  const name = document.getElementById('ad-name').value.trim();
  const age = document.getElementById('ad-age').value;
  const diag = document.getElementById('ad-diag').value.trim();
  const cc = document.getElementById('ad-cc').value.trim();
  if (!name || !age || !diag || !cc) { alert('Name, Age, Diagnosis and Chief Complaint are required.'); return; }

  const icd = document.getElementById('ad-icd').value.trim() || 'Z00';
  const rx = document.getElementById('ad-rx').value.trim();
  const pid = 'P'+Date.now();
  const ehrId = 'EHR-'+Math.floor(10000+Math.random()*90000);

  // IPD-only fields
  const bed = isIPD ? document.getElementById('ad-bed')?.value : '';
  const docId = isIPD ? document.getElementById('ad-doc')?.value : (S.staff.find(s=>s.role==='Doctor')?.id || '');
  const nurseId = isIPD ? document.getElementById('ad-nurse')?.value : '';
  const admType = isIPD ? document.getElementById('ad-type')?.value : 'OPD Consultation';
  const allergy = isIPD ? document.getElementById('ad-allergy')?.value.trim() : 'None Known';
  const bg = isIPD ? document.getElementById('ad-bg')?.value : '';

  const nurse = S.staff.find(s=>s.id===nurseId);
  const doc = S.staff.find(s=>s.id===docId);

  const patient = {
    id: pid, name, age: parseInt(age),
    gender: document.getElementById('ad-gender').value,
    phone: document.getElementById('ad-phone').value.trim(),
    ehrId, diagnosis: diag, icd, bed,
    doctorId: docId, nurseId,
    admissionType: admType,
    admitTime: now(), status: isIPD ? 'Active' : 'OPD',
    chiefComplaint: cc,
    allergies: allergy || 'None Known',
    bloodGroup: bg,
  };

  S.patients.unshift(patient);

  if (isIPD && bed) {
    const bedObj = S.beds.find(b=>b.id===bed);
    if (bedObj) bedObj.status = 'occupied';
  }

  S.vitals[pid] = [];
  S.prescriptions[pid] = [];
  S.labOrders[pid] = [];
  S.mar[pid] = [];
  S.consultNotes[pid] = [];
  S.nursingNotes[pid] = [];
  S.chat[pid] = [];

  if (rx) {
    S.prescriptions[pid].push({ id:'RX'+Date.now(), drug:rx, dose:'', route:'', freq:'', duration:'', instructions:'See free text', prescribedBy:getCurrentStaffName(), time:now(), status:'active' });
    S.notifications.unshift({ id:'N'+Date.now(), role:'Pharmacist', title: isIPD ? 'New Admission Rx' : 'New OPD Rx', body:`${name} — prescription added`, time:ts(), read:false });
  }

  if (isIPD) {
    S.notifications.unshift({ id:'N'+Date.now(), role:'Nurse', title:'New Patient Admitted', body:`${name} assigned to you — Bed ${bed}`, time:ts(), read:false });
  }

  // Push to backend if live
  if (IS_LIVE) {
    const liveResult = await apiPost('/patients', {
      name, age: parseInt(age),
      gender: document.getElementById('ad-gender').value,
      phone: document.getElementById('ad-phone').value.trim(),
      diagnosis: diag, icd, bed,
      doctor_id: docId, nurse_id: nurseId,
      admission_type: admType,
      chief_complaint: cc,
      allergies: allergy || 'None Known',
      blood_group: bg,
