  showModal(`<div class="modal" style="max-width:650px">
    <div class="modal-header"><h2>🧾 Bill — ${b.patientName}</h2><button class="modal-close" onclick="closeModal()">×</button></div>
    <div class="modal-body">
      <div class="flex items-center justify-between mb-3">
        <div><span class="badge ${b.locked?'badge-red':'badge-amber'}">${b.locked?'FINAL — LOCKED':'DRAFT'}</span></div>
        <div class="mono text-muted">${b.ehrId} | ${b.generatedAt}</div>
      </div>
      <table class="data-table mb-3">
        <thead><tr><th>Category</th><th>Particulars</th><th>Rate</th><th>Qty</th><th>Amount</th></tr></thead>
        <tbody>${(b.items||[]).map(i=>`<tr><td>${i.category}</td><td>${i.particulars}</td><td>₹${i.rate}</td><td>${i.qty}</td><td class="fw-600">₹${((i.rate||0)*(i.qty||1)).toLocaleString('en-IN')}</td></tr>`).join('')}</tbody>
      </table>
      <div style="background:var(--panel);border-radius:8px;padding:16px">
        <div class="flex items-center justify-between mb-1"><span>Gross</span><span class="mono">₹${b.gross?.toLocaleString('en-IN')}</span></div>
        <div class="flex items-center justify-between mb-1"><span>Discount</span><span class="mono">−₹${b.discount?.toLocaleString('en-IN')}</span></div>
        <div class="flex items-center justify-between mb-1"><span>Advance</span><span class="mono">−₹${b.advance?.toLocaleString('en-IN')}</span></div>
        <div class="flex items-center justify-between mb-1"><span>Insurance</span><span class="mono">−₹${b.insurance?.toLocaleString('en-IN')}</span></div>
        <div class="flex items-center justify-between" style="border-top:1px solid var(--border);margin-top:8px;padding-top:8px"><span class="fw-600">Net Payable</span><span class="mono fw-600" style="font-size:18px;color:var(--teal)">₹${b.net?.toLocaleString('en-IN')}</span></div>
      </div>
      ${b.insName?`<div class="mt-3 text-muted text-sm">Insurance: ${b.insName} | Policy: ${b.policy||'—'} | Claim: ${b.claim||'—'}</div>`:''}
