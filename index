// VITALS TAB
function renderVitalsTab(id, p) {
  const vlist = S.vitals[id] || [];
  const hasDoctor = S.currentRole === 'Doctor';
  const hasNurse = S.currentRole === 'Nurse';

  // Trend sparkline for BP
  const bpVals = vlist.slice(0,5).map(v=>v.bpSys).reverse();
  const maxBP = Math.max(...bpVals, 120);
  const sparkline = bpVals.length > 1 ? bpVals.map(v => {
    const h = Math.round((v/maxBP)*36);
    const color = v>180?'var(--red)':v>160?'var(--amber)':'var(--teal)';
    return `<div class="trend-bar" style="height:${h}px;background:${color}"></div>`;
  }).join('') : '';

  return `
    <div class="flex items-center justify-between mb-4">
      <div>
        <div class="fw-600">Vitals History</div>
        <div class="text-muted">${vlist.length} entries recorded</div>
      </div>
      ${(hasNurse || hasDoctor) ? `<button class="btn btn-primary" onclick="showRecordVitalsModal('${id}')">➕ Record Vitals</button>` : ''}
    </div>

    ${bpVals.length > 1 ? `
    <div class="card mb-4">
      <div class="card-body">
        <div class="text-sm fw-600 mb-2">BP Trend (last ${bpVals.length} readings)</div>
        <div class="vitals-trend">${sparkline}</div>
        <div class="text-muted text-sm mt-1">Range: ${Math.min(...bpVals)}–${Math.max(...bpVals)} mmHg systolic</div>
      </div>
    </div>` : ''}

    <div class="card">
      <div style="overflow-x:auto">
        <table class="data-table">
          <thead><tr>
            <th>Time</th><th>BP</th><th>Pulse</th><th>SpO₂</th><th>Temp</th><th>RR</th><th>GCS</th><th>UO</th><th>Glucose</th><th>Pain</th><th>Nurse</th><th>Notes</th>
          </tr></thead>
          <tbody>
            ${vlist.length === 0 ? '<tr><td colspan="12" style="text-align:center;padding:20px;color:var(--text-muted)">No vitals recorded yet</td></tr>' : ''}
            ${vlist.map(v => `
              <tr>
                <td class="mono">${v.time}</td>
                <td class="${v.bpSys>180?'critical-val':v.bpSys>160?'warn-val':'normal-val'} mono">${v.bpSys}/${v.bpDia}</td>
                <td class="${v.pulse>130||v.pulse<50?'critical-val':v.pulse>110?'warn-val':''} mono">${v.pulse}</td>
                <td class="${v.spo2<92?'critical-val':v.spo2<95?'warn-val':'normal-val'} mono">${v.spo2}%</td>
                <td class="${v.temp>39.5?'critical-val':v.temp>38.5?'warn-val':''} mono">${v.temp}°C</td>
                <td class="${v.rr>25?'warn-val':''} mono">${v.rr}</td>
                <td class="mono">${v.gcs}</td>
                <td class="${v.uo<20?'warn-val':''} mono">${v.uo} ml/hr</td>
                <td class="mono">${v.glucose} mg/dL</td>
                <td class="mono">${v.pain}/10</td>
                <td>${v.nurse}</td>
                <td style="font-size:11px;color:var(--text-muted)">${v.notes||'—'}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    </div>
  `;
}

