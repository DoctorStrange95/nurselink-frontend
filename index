function startProcessing(pid, labId) {
  const lab = (S.labOrders[pid]||[]).find(l=>l.id===labId);
  if (lab) { lab.status = 'Processing'; save(); showToast('Test moved to Processing'); }
}

function enterResult(pid, labId, testName, patientName) {
  showModal(`<div class="modal">
    <div class="modal-header"><h2>📋 Enter Result — ${testName}</h2><button class="modal-close" onclick="closeModal()">×</button></div>
    <div class="modal-body">
      <div class="text-muted mb-3">Patient: ${patientName}</div>
      <div class="form-group"><label class="form-label">Result Value *</label><textarea class="form-control" id="lr-val" rows="3" placeholder="e.g. Hb: 11.2 g/dL, WBC: 12000/µL..."></textarea></div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Status</label>
          <select class="form-control" id="lr-status"><option>Normal</option><option>Abnormal</option><option>Critical</option></select>
        </div>
        <div class="form-group"><label class="form-label">Reference Range (optional)</label><input class="form-control" id="lr-ref" placeholder="e.g. 12–16 g/dL"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-primary" onclick="submitLabResult('${pid}','${labId}','${patientName}')">Submit Result</button>
    </div>
  </div>`);
}

function submitLabResult(pid, labId, patientName) {
  const val = document.getElementById('lr-val').value.trim();
  const status = document.getElementById('lr-status').value;
  const ref = document.getElementById('lr-ref').value.trim();
  if (!val) { alert('Result value required.'); return; }
  const lab = (S.labOrders[pid]||[]).find(l=>l.id===labId);
  if (lab) {
    lab.status = 'Result Available';
    lab.result = val + (ref?` [Ref: ${ref}]`:'');
    lab.resultStatus = status;
  }
  S.notifications.unshift({ id:'N'+Date.now(), role:'Doctor', title:`Lab Result: ${lab?.test}`, body:`${patientName} — ${status}`, time:ts(), read:false });
  if (status === 'Critical') {
    S.alerts.unshift({ id:'A'+Date.now(), patientId:pid, type:'critical', title:'CRITICAL LAB RESULT', msg:`${lab?.test}: ${val}`, time:ts(), acked:false });
    showToast(`CRITICAL RESULT alerted to Doctor`, 'error');
  }
  closeModal();
  showToast('Result submitted');
  save();
}

