    const rx = (S.prescriptions[pid]||[]).find(r=>r.id===rxId);
    if (rx) rx.status = 'dispensed';
    S.notifications.unshift({ id:'N'+Date.now(), role:'Nurse', title:'Drug Dispensed', body:`${p?.name} — ${drugName} dispensed`, time:ts(), read:false });
    showToast(`${drugName} dispensed for ${p?.name}`);
  } else {
    S.notifications.unshift({ id:'N'+Date.now(), role:'Nurse', title:'Drug Out of Stock', body:`${p?.name} — ${drugName} not available`, time:ts(), read:false });
    showToast(`Nurse alerted: ${drugName} out of stock`, 'warn');
  }
  save();
}

