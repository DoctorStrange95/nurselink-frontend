async function submitLabOrder(pid) {
  const checkboxes = document.querySelectorAll('#modal-container input[type=checkbox]:checked:not(:disabled)');
  if (checkboxes.length === 0) { alert('Select at least one test.'); return; }
  if (!S.labOrders[pid]) S.labOrders[pid] = [];
  const tests = [];
  checkboxes.forEach(cb => {
    const t = cb.value;
    const priSel = document.getElementById('pri-' + t.replace(/\s/g,'_'));
    const priority = priSel ? priSel.value : 'Routine';
    const lab = { id:'L'+Date.now()+Math.random(), test:t, category:'', priority, status:'Pending', result:'', resultStatus:'', orderedBy:getCurrentStaffName(), time:now() };
    S.labOrders[pid].unshift(lab);
    tests.push(lab);
  });
  S.notifications.unshift({ id:'N'+Date.now(), role:'Lab Tech', title:'New Lab Orders', body:`${S.patients.find(p=>p.id===pid)?.name} — ${tests.length} test(s) ordered`, time:ts(), read:false });
