// ============================================================
// PATIENT REGISTRATION (Counter Staff)
// ============================================================
function generateUHID() {
  const yr = new Date().getFullYear();
  const num = String(Math.floor(10000+Math.random()*90000));
  return `INST-${yr}-${num}`;
}

function renderRegisterPage() {
  const main = document.getElementById('main');
  main.innerHTML = `
    <div class="section-title">Register New Patient</div>
    <div class="section-sub">UHID is auto-generated on save</div>
    <div class="card">
      <div class="card-header"><h3>Patient Demographics</h3></div>
      <div class="card-body">
        <div class="form-row">
          <div class="form-group"><label class="form-label">First Name *</label><input class="form-control" id="reg-fname" placeholder="First name"></div>
          <div class="form-group"><label class="form-label">Last Name *</label><input class="form-control" id="reg-lname" placeholder="Last name"></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Age *</label><input class="form-control" id="reg-age" type="number" placeholder="Age"></div>
          <div class="form-group"><label class="form-label">Gender *</label><select class="form-control" id="reg-gender"><option value="M">Male</option><option value="F">Female</option><option value="O">Other</option></select></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Phone Number</label><input class="form-control" id="reg-phone" placeholder="10-digit mobile" oninput="checkExistingPatient(this.value)"></div>
          <div class="form-group"><label class="form-label">Blood Group</label><select class="form-control" id="reg-bg"><option>A+</option><option>A-</option><option>B+</option><option>B-</option><option>O+</option><option>O-</option><option>AB+</option><option>AB-</option></select></div>
        </div>
        <div id="existing-patient-alert" style="display:none" class="alert-item warning mb-3"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Height (cm)</label><input class="form-control" id="reg-height" type="number" placeholder="165" oninput="calcBMI()"></div>
          <div class="form-group"><label class="form-label">Weight (kg)</label><input class="form-control" id="reg-weight" type="number" placeholder="70" oninput="calcBMI()"></div>
        </div>
        <div class="form-group"><label class="form-label">BMI (auto-calculated)</label><input class="form-control" id="reg-bmi" readonly placeholder="Enter height & weight"></div>
        <div class="form-group"><label class="form-label">Chief Complaint</label><textarea class="form-control" id="reg-cc" rows="2" placeholder="Presenting complaint..."></textarea></div>
      </div>
    </div>
    <div class="card mt-4">
      <div class="card-header"><h3>Vitals (optional)</h3></div>
      <div class="card-body">
        <div class="form-row-3">
          <div class="form-group"><label class="form-label">BP (Sys/Dia)</label><div class="flex gap-2"><input class="form-control" id="reg-bps" type="number" placeholder="120"><input class="form-control" id="reg-bpd" type="number" placeholder="80"></div></div>
          <div class="form-group"><label class="form-label">Pulse (bpm)</label><input class="form-control" id="reg-pulse" type="number" placeholder="72"></div>
          <div class="form-group"><label class="form-label">SpO2 (%)</label><input class="form-control" id="reg-spo2" type="number" placeholder="98"></div>
        </div>
      </div>
    </div>
    <div class="flex gap-3 mt-4">
      <button class="btn btn-primary" onclick="saveRegistration()">✔ Register & Generate UHID</button>
      <button class="btn btn-outline" onclick="setNav('queue')">Cancel</button>
    </div>
  `;
}

function calcBMI() {
  const h = parseFloat(document.getElementById('reg-height')?.value);
  const w = parseFloat(document.getElementById('reg-weight')?.value);
  if (h && w) {
    const bmi = (w / Math.pow(h/100, 2)).toFixed(1);
    document.getElementById('reg-bmi').value = bmi;
  }
}

function checkExistingPatient(phone) {
  if (phone.length < 10) { document.getElementById('existing-patient-alert').style.display='none'; return; }
  const existing = S.patients.find(p=>p.phone===phone);
  const el = document.getElementById('existing-patient-alert');
  if (existing) {
    el.style.display = 'block';
    el.innerHTML = `<div class="al-title">⚠ Existing patient found</div><div class="al-meta">${existing.name}, ${existing.age} yrs — UHID: ${existing.ehrId}. <a href="#" onclick="openPatient('${existing.id}');closeModal()" style="color:var(--teal)">Open record</a> or continue to create new.</div>`;
  } else {
    el.style.display = 'none';
  }
}

function saveRegistration() {
  const fname = document.getElementById('reg-fname').value.trim();
  const lname = document.getElementById('reg-lname').value.trim();
  const age = document.getElementById('reg-age').value;
  if (!fname || !lname || !age) { alert('First name, last name and age are required.'); return; }
  const uhid = generateUHID();
  const pid = 'P'+Date.now();
  const patient = {
    id:pid, name:`${fname} ${lname}`, age:parseInt(age),
    gender:document.getElementById('reg-gender').value,
    phone:document.getElementById('reg-phone').value.trim(),
    ehrId:uhid, diagnosis:'', icd:'', bed:'',
    doctorId:'', nurseId:'',
    admissionType:'OPD', admitTime:now(), status:'OPD',
    chiefComplaint:document.getElementById('reg-cc').value.trim(),
    allergies:'None Known', bloodGroup:document.getElementById('reg-bg').value,
    height:document.getElementById('reg-height').value,
    weight:document.getElementById('reg-weight').value,
    bmi:document.getElementById('reg-bmi').value,
  };
  S.patients.unshift(patient);
  S.vitals[pid] = [];
  S.prescriptions[pid] = [];
  S.labOrders[pid] = [];
  S.consultNotes[pid] = [];
  S.nursingNotes[pid] = [];
  S.chat[pid] = [];
  // Add initial vitals if entered
  const bps = parseInt(document.getElementById('reg-bps').value);
  const bpd = parseInt(document.getElementById('reg-bpd').value);
  const pulse = parseInt(document.getElementById('reg-pulse').value);
  const spo2 = parseInt(document.getElementById('reg-spo2').value);
  if (bps && bpd && pulse) {
    S.vitals[pid].push({ id:'V'+Date.now(), time:ts(), bpSys:bps, bpDia:bpd, pulse, spo2:spo2||98, temp:37.0, rr:18, gcs:15, uo:40, glucose:100, drain:0, pain:0, notes:'Registration vitals', nurse:getCurrentStaffName() });
  }
  // Add to OPD queue
  if (!S.opdQueue) S.opdQueue = [];
  S.opdQueue.unshift({ pid, name:patient.name, uhid, cc:patient.chiefComplaint, time:ts(), status:'Waiting' });
  showToast(`UHID generated: ${uhid}`);
  showModal(`<div class="modal"><div class="modal-header"><h2>✅ Patient Registered</h2><button class="modal-close" onclick="closeModal()">×</button></div>
    <div class="modal-body" style="text-align:center">
      <div style="font-size:32px;font-weight:800;color:var(--teal);letter-spacing:2px">${uhid}</div>
      <div class="text-muted mt-2">Share this UHID with the patient</div>
      <div style="margin-top:16px;font-size:14px"><b>${patient.name}</b> | ${patient.age} yrs | ${patient.gender==='M'?'Male':patient.gender==='F'?'Female':'Other'}</div>
    </div>
    <div class="modal-footer"><button class="btn btn-primary" onclick="closeModal();setNav('queue')">Go to Queue</button></div>
  </div>`);
  save();
}

// ============================================================
// OPD QUEUE (Counter / Doctor)
// ============================================================
function renderQueuePage() {
  const main = document.getElementById('main');
  if (!S.opdQueue) S.opdQueue = [];
  const waiting = S.opdQueue.filter(q=>q.status==='Waiting');
  const called = S.opdQueue.filter(q=>q.status==='Called');
  const done = S.opdQueue.filter(q=>q.status==='Done');
  main.innerHTML = `
    <div class="flex items-center justify-between mb-4">
      <div>
        <div class="section-title">OPD Queue</div>
        <div class="section-sub">${waiting.length} waiting · ${called.length} with doctor · ${done.length} done today</div>
      </div>
      <button class="btn btn-primary" onclick="setNav('register')">➕ Register Patient</button>
    </div>
    <div class="grid-3">
      <div>
        <div style="font-size:12px;font-weight:700;color:var(--amber);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">⏳ Waiting (${waiting.length})</div>
        ${waiting.map((q,i)=>`
          <div class="card mb-3" style="border-left:3px solid var(--amber)">
            <div class="card-body">
              <div class="flex items-center justify-between mb-1">
                <span style="font-size:18px;font-weight:800;color:var(--amber)">#${i+1}</span>
                <span class="mono text-muted" style="font-size:11px">${q.time}</span>
              </div>
              <div class="fw-600">${q.name}</div>
              <div class="mono text-muted" style="font-size:11px">${q.uhid}</div>
              <div class="text-muted mt-1" style="font-size:12px">${q.cc||'No complaint noted'}</div>
              <div class="flex gap-2 mt-2">
                <button class="btn btn-primary btn-sm" onclick="callPatient('${q.pid}')">📣 Call</button>
                <button class="btn btn-outline btn-sm" onclick="openPatient('${q.pid}')">View →</button>
              </div>
            </div>
          </div>
        `).join('')||'<div class="text-muted" style="font-size:13px">Queue is empty</div>'}
      </div>
      <div>
        <div style="font-size:12px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">🩺 With Doctor (${called.length})</div>
        ${called.map(q=>`
          <div class="card mb-3" style="border-left:3px solid var(--teal)">
            <div class="card-body">
              <div class="fw-600">${q.name}</div>
              <div class="mono text-muted" style="font-size:11px">${q.uhid}</div>
              <button class="btn btn-success btn-sm mt-2" onclick="markQueueDone('${q.pid}')">✔ Done</button>
            </div>
          </div>
        `).join('')||'<div class="text-muted" style="font-size:13px">No active consultations</div>'}
      </div>
      <div>
        <div style="font-size:12px;font-weight:700;color:var(--emerald);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">✅ Done Today (${done.length})</div>
        ${done.slice(0,5).map(q=>`
          <div class="card mb-2" style="border-left:3px solid var(--emerald);opacity:0.7">
            <div class="card-body" style="padding:10px 12px">
              <div class="fw-600" style="font-size:13px">${q.name}</div>
              <div class="mono text-muted" style="font-size:11px">${q.uhid}</div>
            </div>
          </div>
        `).join('')||'<div class="text-muted" style="font-size:13px">None yet</div>'}
      </div>
    </div>
  `;
}

function callPatient(pid) {
  if (!S.opdQueue) return;
  const q = S.opdQueue.find(x=>x.pid===pid);
  if (q) { q.status='Called'; save(); }
}

function markQueueDone(pid) {
  if (!S.opdQueue) return;
  const q = S.opdQueue.find(x=>x.pid===pid);
  if (q) { q.status='Done'; save(); }
}

