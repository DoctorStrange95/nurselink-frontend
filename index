function save() {
  try { localStorage.setItem('NL_STATE_V3', JSON.stringify(S)); } catch(e) {}
  // Only do a full re-render if no modal is open and no patient is being consulted
  // This prevents wiping half-filled forms
  const modalOpen = !!document.getElementById('modal-container').innerHTML;
  const activeView = S.activeNavItem[S.currentRole] || getDefaultView();
  const formViews = ['admit','register'];
  const inForm = formViews.includes(activeView) && !S.activePatientId;
  const inOPDConsult = S.activePatientId &&
    S.patients.find(p => p.id === S.activePatientId)?.status === 'OPD';

  if (modalOpen || inForm || inOPDConsult) {
    // Partial update only — don't touch main content
    renderSidebar();
    renderAlertFeed();
    renderNotifBadge();
    renderTopbar();
  } else {
    renderAll();
  }
}

function saveState() {
  // Silent save — no re-render at all, used for timer ticks etc
  try { localStorage.setItem('NL_STATE_V3', JSON.stringify(S)); } catch(e) {}
}

function resetState() {
  S = JSON.parse(JSON.stringify(INIT));
  save();
}

