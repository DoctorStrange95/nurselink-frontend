  const pid='P'+Date.now();
  const ehr='EHR-'+Math.floor(10000+Math.random()*90000);
  const p={id:pid,name,age:parseInt(age),gender:document.getElementById('ag').value,phone:document.getElementById('aph').value.trim(),ehr,diag,icd:document.getElementById('aicd').value.trim()||'Z00',bed,doc:docId,nurse:nurId,type:document.getElementById('atyp').value,admit:NOW(),status:'Active',cc,allergy:document.getElementById('aal').value.trim()||'None Known',bg:document.getElementById('abg').value};
  S.patients.unshift(p);
  const bedObj=S.beds.find(b=>b.id===bed); if(bedObj) bedObj.status='occupied';
  S.vitals[pid]=[]; S.rx[pid]=[]; S.labs[pid]=[]; S.cn[pid]=[]; S.nn[pid]=[]; S.chat[pid]=[]; S.mar[pid]=[];
  S.notifs.unshift({id:'N'+Date.now(),role:'Nurse',title:'New Admission',body:`${name} — Bed ${bed}`,t:TS(),read:false});
  if(IS_LIVE){const r=await apip('/patients',{name,age:parseInt(age),gender:p.gender,phone:p.phone,blood_group:p.bg,allergies:p.allergy,chief_complaint:cc,diagnosis:diag,icd_code:p.icd,bed,doctor_id:docId,nurse_id:nurId,admission_type:p.type});showToast(r?`${name} admitted ✓`:'Saved locally');}
  else showToast(`${name} admitted`);
  save();
}

function renderAlertsPage(){
  const main=document.getElementById('main');
  main.innerHTML=`<div class="st">Alerts</div><div class="ss">${S.alerts.filter(a=>!a.acked).length} pending</div>`+
    S.alerts.map(a=>`<div class="ai ${a.type}" style="${a.acked?'opacity:.5':''}">
      <div class="flex ic jb"><div class="ai-t">${a.title} — ${S.patients.find(p=>p.id===a.pid)?.name||''}</div><span class="badge ${a.acked?'bg':'br'}">${a.acked?'Acked':'Pending'}</span></div>
      <div class="ai-m">${a.msg} · ${a.t}</div>
      ${!a.acked&&S.role==='Doctor'?`<button style="margin-top:6px;font-size:10px;padding:3px 10px;border:1px solid var(--border);border-radius:5px;cursor:pointer;background:white" onclick="ackAlert('${a.id}')">Acknowledge</button>`:''}
    </div>`).join('');
}

function renderDischargePage(){
  const main=document.getElementById('main');
  main.innerHTML=`<div class="st">Discharge Management</div><div class="ss">Generate discharge summaries</div>`+
    S.patients.filter(p=>p.status==='Active').map(p=>`<div class="card"><div class="cb flex ic jb">
      <div><div class="fw6">${p.name} <span class="tm fs11">· Bed ${p.bed||'—'}</span></div><div class="tm">${p.diag||'—'} · Admitted ${p.admit}</div></div>
      <button class="btn btn-w btn-sm" onclick="showDC('${p.id}')">📄 Discharge</button>
    </div></div>`).join('');
}

function markDC(pid){S.nav='discharge';S.pid=null;save();}

function showDC(pid){
  const p=S.patients.find(x=>x.id===pid);
  const v=(S.vitals[pid]||[])[0];
  const rx=(S.rx[pid]||[]).filter(r=>r.status==='active');
  const labs=(S.labs[pid]||[]).filter(l=>l.result);
  showModal(`<div class="md md-lg">
    <div class="mh"><h2>📄 Discharge Summary — ${p.name}</h2><button class="mclose" onclick="closeModal()">×</button></div>
    <div class="mc">
      <div class="ds-sec"><div class="ds-hdr">Patient</div><div class="ds-body"><b>${p.name}</b> · ${p.age}${p.gender==='M'?'M':'F'} · ${p.bg||'—'} · ${p.phone||'—'}<br>EHR: ${p.ehr} · Bed: ${p.bed||'—'} · Admitted: ${p.admit}<br>Allergies: ${p.allergy||'None Known'}</div></div>
      <div class="ds-sec"><div class="ds-hdr">Diagnosis</div><div class="ds-body"><b>${p.diag||'—'}</b> (ICD-10: ${p.icd||'—'})<br>${p.cc||''}</div></div>
      ${v?`<div class="ds-sec"><div class="ds-hdr">Vitals at Discharge</div><div class="ds-body mono" style="font-size:12px">BP: ${v.bps}/${v.bpd} · Pulse: ${v.pr} · SpO₂: ${v.sp}% · Temp: ${v.tmp}°C · GCS: ${v.gcs}/15</div></div>`:''}
      <div class="ds-sec"><div class="ds-hdr">Discharge Medications</div><div class="ds-body">${rx.length?rx.map(r=>`• ${r.drug} ${r.dose} ${r.route} ${r.freq} × ${r.dur}`).join('<br>'):'None'}</div></div>
      ${labs.length?`<div class="ds-sec"><div class="ds-hdr">Lab Results</div><div class="ds-body mono" style="font-size:12px">${labs.map(l=>`• ${l.test}: ${l.result}`).join('<br>')}</div></div>`:''}
      <div class="fg mt4"><label class="fl">Follow-up Instructions</label><textarea class="fc" id="dc-fu" rows="3" placeholder="Diet, activity, follow-up date…"></textarea></div>
      <div class="fg"><label class="fl">Discharge Condition</label><select class="fc" id="dc-cond" style="width:auto"><option>Stable</option><option>Improved</option><option>Against Medical Advice (LAMA)</option><option>Transferred</option><option>Expired</option></select></div>
    </div>
    <div class="mf"><button class="btn btn-o" onclick="closeModal()">Close</button><button class="btn btn-s" onclick="finalizeDC('${pid}')">✔ Finalize & Discharge</button></div>
  </div>`);
}

async function finalizeDC(pid){
  const p=S.patients.find(x=>x.id===pid);
  const cond=document.getElementById('dc-cond').value;
  p.status='Discharged'; p.dischargeTime=NOW(); p.dischargeCond=cond;
  const bed=S.beds.find(b=>b.id===p.bed); if(bed) bed.status='available';
  S.notifs.unshift({id:'N'+Date.now(),role:'Nurse',title:'Patient Discharged',body:`${p.name} — ${cond}`,t:TS(),read:false});
  if(IS_LIVE) await apipa('/patients/'+pid+'/discharge',{condition:cond});
  closeModal(); showToast(`${p.name} discharged — ${cond}`); save();
}

function renderVitalsPage(){
  const mn=myName();
  const pts=S.patients.filter(p=>p.status==='Active'&&(S.role==='Doctor'||S.staff.find(s=>s.id===p.nurse)?.name===mn));
  const main=document.getElementById('main');
  main.innerHTML=`<div class="st mb4">Vitals Entry</div>`+
    pts.map(p=>{const v=(S.vitals[p.id]||[])[0];return `<div class="card"><div class="cb flex ic jb"><div><div class="fw6">${p.name} <span class="tm fs11">· Bed ${p.bed||'—'}</span></div>${v?`<div class="tm">Last: BP ${v.bps}/${v.bpd}, SpO₂ ${v.sp}% @ ${v.t}</div>`:'<div class="tm">No vitals yet</div>'}</div><button class="btn btn-p btn-sm" onclick="showVitalsModal('${p.id}')">📊 Record</button></div></div>`;}).join('');
}

function renderMARPage(){
  const mn=myName();
  const pts=S.patients.filter(p=>p.status==='Active'&&S.staff.find(s=>s.id===p.nurse)?.name===mn);
  const main=document.getElementById('main');
  main.innerHTML=`<div class="st mb4">Medication MAR</div>`+
    pts.map(p=>{
      const rx=(S.rx[p.id]||[]).filter(r=>r.status==='active');
      return `<div class="card"><div class="ch"><h3>${p.name} — Bed ${p.bed||'—'}</h3><span class="tm fs11">${rx.length} active</span></div><div class="cb">
        ${rx.length===0?'<div class="tm">No active medications</div>':''}
        ${rx.map(r=>{const last=(S.mar[p.id]||[]).find(m=>m.rxId===r.id);return `<div class="mr"><div class="mr-drug"><div class="mr-dn">${r.drug}</div><div class="mr-dd">${r.dose} · ${r.route} · ${r.freq}</div>${last?`<div class="mr-log">Last: ${last.status} @ ${last.t}</div>`:''}</div><div class="flex" style="gap:6px"><button class="mb gv ${last?.status==='Given'?'on':''}" onclick="recMAR('${p.id}','${r.id}','Given')">✔ Given</button><button class="mb hl" onclick="recMAR('${p.id}','${r.id}','Held')">⏸ Hold</button><button class="mb na ${last?.status==='Not Available'?'on':''}" onclick="recMAR('${p.id}','${r.id}','Not Available')">⚠ N/A</button></div></div>`;}).join('')}
      </div></div>`;
    }).join('');
}

function renderNotesPage(){
  const mn=myName();
  const pts=S.patients.filter(p=>p.status==='Active'&&S.staff.find(s=>s.id===p.nurse)?.name===mn);
  const main=document.getElementById('main');
  main.innerHTML=`<div class="st mb4">Nursing Notes</div>`+
    pts.map(p=>`<div class="card"><div class="ch"><h3>${p.name}</h3><button class="btn btn-p btn-sm" onclick="showNNModal('${p.id}')">+ Add</button></div><div class="cb">${(S.nn[p.id]||[]).length===0?'<div class="tm">No notes yet</div>':(S.nn[p.id]||[]).map(n=>`<div style="border-bottom:1px solid var(--border);padding:7px 0"><div class="flex ic jb mb2"><span class="fw6 fs12">${n.by}</span><span class="tm fs11">${n.t}</span></div><div style="font-size:13px">${n.note}</div></div>`).join('')}</div></div>`).join('');
}

function renderPharmacy(){
  const main=document.getElementById('main');
  main.innerHTML=`<div class="st mb4">Pharmacy — Prescriptions</div>`;
  let html='';
  S.patients.forEach(p=>{
    const rx=(S.rx[p.id]||[]).filter(r=>r.status==='active');
    if(!rx.length) return;
    html+=`<div class="card"><div class="ch"><h3>${p.name} — Bed ${p.bed||'—'}</h3></div><div class="cb">
      ${rx.map(r=>{const st=S.pharmSt[r.id]||'pending';return `<div style="display:flex;align-items:center;gap:12px;padding:10px;background:var(--panel);border-radius:8px;margin-bottom:7px">
        <div style="flex:1"><div class="fw6" style="font-size:13px">${r.drug}</div><div class="mono tm">${r.dose} · ${r.route} · ${r.freq}</div></div>
        <span class="badge ${st==='dispensed'?'bg':st==='oos'?'br':'ba'}">${st==='oos'?'OUT OF STOCK':st.toUpperCase()}</span>
        <button class="btn btn-s btn-xs" onclick="pharmDo('${r.id}','${p.id}','dispensed','${r.drug}')">✔ Dispense</button>
        <button class="btn btn-d btn-xs" onclick="pharmDo('${r.id}','${p.id}','oos','${r.drug}')">✗ OOS</button>
      </div>`;}).join('')}
    </div></div>`;
  });
  main.innerHTML+=html||'<div class="tm">No active prescriptions.</div>';
}

function pharmDo(rxId,pid,status,drug){
  S.pharmSt[rxId]=status;
  const p=S.patients.find(x=>x.id===pid);
  if(status==='dispensed'){const r=(S.rx[pid]||[]).find(x=>x.id===rxId);if(r) r.status='dispensed';S.notifs.unshift({id:'N'+Date.now(),role:'Nurse',title:'Dispensed',body:`${p?.name} — ${drug}`,t:TS(),read:false});showToast(`${drug} dispensed`);}
  else{S.notifs.unshift({id:'N'+Date.now(),role:'Nurse',title:'Out of Stock',body:`${p?.name} — ${drug}`,t:TS(),read:false});showToast(`${drug} OOS`,'wrn');}
  save();
}

function renderLabTech(){
  const orders=[];
  S.patients.forEach(p=>(S.labs[p.id]||[]).filter(l=>l.status!=='Result Available').forEach(l=>orders.push({...l,pn:p.name,ehr:p.ehr,pid:p.id})));
  orders.sort((a,b)=>(a.pri==='STAT'?0:a.pri==='Urgent'?1:2)-(b.pri==='STAT'?0:b.pri==='Urgent'?1:2));
  const main=document.getElementById('main');
  main.innerHTML=`<div class="st">Lab Orders</div><div class="ss">${orders.length} pending</div>`+
    (orders.length===0?'<div class="tm">No pending orders.</div>':'')+
    orders.map(l=>`<div class="card"><div class="cb">
      <div class="flex ic jb">
        <div><div class="fw6">${l.test}</div><div class="tm fs11">${l.pn} · ${l.ehr} · by ${l.by}</div></div>
        <div class="flex" style="gap:6px">
          <span class="badge ${l.pri==='STAT'?'br':l.pri==='Urgent'?'ba':'bt'}">${l.pri}</span>
          <span class="badge ${l.status==='Processing'?'ba':'bi'}">${l.status}</span>
        </div>
      </div>
      <div class="flex mt2" style="gap:8px">
        ${l.status==='Pending'?`<button class="btn btn-o btn-sm" onclick="startLab('${l.pid}','${l.id}')">▶ Start</button>`:''}
        ${l.status==='Processing'?`<button class="btn btn-p btn-sm" onclick="enterResult('${l.pid}','${l.id}','${l.test}','${l.pn}')">📋 Enter Result</button>`:''}
      </div>
    </div></div>`).join('');
}

function startLab(pid,lid){
  const l=(S.labs[pid]||[]).find(x=>x.id===lid);
  if(l){l.status='Processing';save();showToast('Test started');}
}

function enterResult(pid,lid,test,pn){
  showModal(`<div class="md">
    <div class="mh"><h2>📋 Enter Result — ${test}</h2><button class="mclose" onclick="closeModal()">×</button></div>
    <div class="mc">
      <div class="tm mb4">Patient: ${pn}</div>
      <div class="fg"><label class="fl">Result *</label><textarea class="fc" id="lr" rows="3" placeholder="e.g. Hb: 11.2 g/dL, WBC: 12000/µL"></textarea></div>
      <div class="fr2">
        <div class="fg"><label class="fl">Status</label><select class="fc" id="lrs"><option>Normal</option><option>Abnormal</option><option>Critical</option></select></div>
        <div class="fg"><label class="fl">Reference Range</label><input class="fc" id="lrr" placeholder="e.g. 12–16 g/dL"></div>
      </div>
    </div>
    <div class="mf"><button class="btn btn-o" onclick="closeModal()">Cancel</button><button class="btn btn-p" onclick="submitResult('${pid}','${lid}','${test}','${pn}')">Submit</button></div>
  </div>`);
}

async function submitResult(pid,lid,test,pn){
  const val=document.getElementById('lr').value.trim();
  if(!val){alert('Result required.');return;}
  const rs=document.getElementById('lrs').value;
  const rr=document.getElementById('lrr').value.trim();
  const l=(S.labs[pid]||[]).find(x=>x.id===lid);
  if(l){l.status='Result Available';l.result=val+(rr?' [Ref: '+rr+']':'');l.rs=rs;}
  S.notifs.unshift({id:'N'+Date.now(),role:'Doctor',title:`Lab Result: ${test}`,body:`${pn} — ${rs}`,t:TS(),read:false});
  if(rs==='Critical'){S.alerts.unshift({id:'A'+Date.now(),pid,type:'critical',title:'CRITICAL LAB RESULT',msg:`${test}: ${val}`,t:TS(),acked:false});showToast('CRITICAL result — Doctor alerted','err');}
  if(IS_LIVE) await apipa('/labs/'+lid+'/result',{result:val+(rr?' [Ref: '+rr+']':''),result_status:rs});
  closeModal(); showToast('Result submitted'); save();
}

function renderStaff(){
  const main=document.getElementById('main');
  const roleColors={Doctor:'var(--teal)',Nurse:'var(--indigo)',Pharmacist:'var(--emerald)','Lab Tech':'var(--amber)',Admin:'var(--slate)'};
  main.innerHTML=`
    <div class="flex ic jb mb4">
      <div><div class="st">Staff</div><div class="ss">${S.staff.length} members</div></div>
      <button class="btn btn-p btn-sm" onclick="showAddStaff()">➕ Add Staff</button>
    </div>
