async function submitVitals(pid){
  const bps=parseInt(document.getElementById('vbps').value);
  const bpd=parseInt(document.getElementById('vbpd').value);
  const pr=parseInt(document.getElementById('vpr').value);
  const sp=parseInt(document.getElementById('vsp').value);
  if(!bps||!bpd||!pr||!sp){alert('BP, Pulse and SpO2 are required.');return;}
  const tmp=parseFloat(document.getElementById('vtmp').value)||37.0;
  const rr=parseInt(document.getElementById('vrr').value)||18;
  const gcs=parseInt(document.getElementById('vgcs').value)||15;
  const uo=parseInt(document.getElementById('vuo').value)||40;
  const gl=parseInt(document.getElementById('vgl').value)||100;
  const pa=parseInt(document.getElementById('vpa').value)||0;
  const nt=document.getElementById('vnt').value.trim();
  const v={id:'V'+Date.now(),t:TS(),bps,bpd,pr,sp,tmp,rr,gcs,uo,gl,pa,nt,by:myName()};
  if(!S.vitals[pid]) S.vitals[pid]=[];
  S.vitals[pid].unshift(v);
  checkAlerts(pid,v);
  closeModal();
  if(IS_LIVE){
    const r=await apip('/vitals/'+pid,{bp_sys:bps,bp_dia:bpd,pulse:pr,spo2:sp,temperature:tmp,resp_rate:rr,gcs,urine_output:uo,blood_glucose:gl,drain_output:0,pain_score:pa,notes:nt});
    showToast(r?'Vitals saved ✓':'Saved locally','info');
    if(r){const alts=await apig('/alerts');if(alts) S.alerts=alts.map(a=>({id:String(a.id),pid:String(a.patient_id),type:a.type,title:a.title,msg:a.message||'',t:a.created_at?new Date(a.created_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}):'',acked:!!a.acknowledged_by}));}
  } else showToast('Vitals recorded ✓');
  save();
}

