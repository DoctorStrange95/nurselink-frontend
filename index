function vstat(v){
  if(!v) return 'n';
  if(v.bps>180||v.bps<90||v.sp<92||v.pr>130||v.pr<50||v.tmp>39.5) return 'c';
  if(v.bps>160||v.sp<95||v.pr>110||v.tmp>38.5||v.rr>25) return 'w';
  return 'n';
}

function renderPatients(){
  let pts=S.patients.filter(p=>p.status==='Active');
  if(S.role==='Nurse'){const mn=myName();pts=pts.filter(p=>{const n=S.staff.find(s=>s.id===p.nurse);return n&&n.name===mn;});}
  else if(S.role==='Doctor'){const mn=myName();pts=pts.filter(p=>{const d=S.staff.find(s=>s.id===p.doc);return d&&d.name===mn;});}
  const main=document.getElementById('main');
  main.innerHTML=`
    <div class="flex ic jb mb4">
      <div><div class="st">${S.role==='Nurse'?'My Patients':'My Patients'}</div><div class="ss">${pts.length} active</div></div>
      ${S.role==='Doctor'?`<button class="btn btn-p" onclick="setNav('admit')">➕ Admit Patient</button>`:''}
    </div>
    <div class="pg">${pts.map(p=>renderPC(p)).join('')}</div>
  `;
}

