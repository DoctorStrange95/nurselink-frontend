function rxSug(val){
  const box=document.getElementById('rx-sug');
  if(!val||val.length<2){box.style.display='none';return;}
  const m=DRUGS.filter(d=>d.toLowerCase().includes(val.toLowerCase())).slice(0,8);
  if(!m.length){box.style.display='none';return;}
  box.style.display='block';
