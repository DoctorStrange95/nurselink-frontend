async function submitMed(pid) {
  const drug = document.getElementById('rx-drug').value.trim();
  const dose = document.getElementById('rx-dose').value.trim();
  const route = document.getElementById('rx-route').value;
  const freq = document.getElementById('rx-freq').value;
  const dur = document.getElementById('rx-dur').value.trim() || 'Till review';
  const inst = document.getElementById('rx-inst').value.trim();
  if (!drug || !dose) { alert('Drug name and dose required.'); return; }
  if (!S.prescriptions[pid]) S.prescriptions[pid] = [];
  const rx = { id:'RX'+Date.now(), drug, dose, route, freq, duration:dur, instructions:inst, prescribedBy:getCurrentStaffName(), time:now(), status:'active' };
  S.prescriptions[pid].unshift(rx);
  S.notifications.unshift({ id:'N'+Date.now(), role:'Pharmacist', title:'New Prescription', body:`${S.patients.find(p=>p.id===pid)?.name} — ${drug} ${dose}`, time:ts(), read:false });
  closeModal();

  if (IS_LIVE) {
    const res = await apiPost('/prescriptions/' + pid, { drug, dose, route, frequency:freq, duration:dur, instructions:inst });
    showToast(res ? 'Prescription saved & sent to Pharmacy ✓' : 'Saved locally — server sync failed', res ? 'info' : 'warn');
  } else { showToast('Prescription added & sent to Pharmacy'); }
  save();
}

async function discontinueMed(pid, rxId) {
  const rx = (S.prescriptions[pid]||[]).find(r=>r.id===rxId);
  if (!rx) return;
  rx.status = 'discontinued';
  rx.dcBy = getCurrentStaffName();
  rx.dcTime = now();
  S.notifications.unshift({ id:'N'+Date.now(), role:'Nurse', title:"Medication DC'd", body:`${rx.drug} discontinued by ${getCurrentStaffName()}`, time:ts(), read:false });
  showToast(`${rx.drug} discontinued`);
  if (IS_LIVE) await apiPatch('/prescriptions/' + rxId + '/discontinue', {});
  save();
}

