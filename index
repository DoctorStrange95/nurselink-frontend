async function doLogin(){
  const email=document.getElementById('li-e').value.trim();
  const pwd=document.getElementById('li-p').value;
  const btn=document.getElementById('li-btn');
  const err=document.getElementById('le');
  err.style.display='none'; btn.textContent='Signing in…'; btn.disabled=true;
  try{
    const res=await fetch(API+'/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,password:pwd})});
    const data=await res.json();
    if(!res.ok) throw new Error(data.error||'Login failed');
    TOKEN=data.token; USER=data.user;
    // map role from server
    const rm={Doctor:'Doctor',Nurse:'Nurse',Pharmacist:'Pharmacist','Lab Tech':'Lab Tech',Admin:'Admin'};
    S.role=rm[USER.role]||'Doctor';
    localStorage.setItem('nl_tok',TOKEN);
    localStorage.setItem('nl_usr',JSON.stringify(USER));
    IS_LIVE=true;
    await syncLiveData();
    startApp();
  }catch(e){
    err.textContent=e.message; err.style.display='block';
    btn.textContent='Sign In'; btn.disabled=false;
  }
}

function demoMode(){IS_LIVE=false;startApp();}

function doLogout(){
  TOKEN=null;USER=null;IS_LIVE=false;
  localStorage.removeItem('nl_tok');localStorage.removeItem('nl_usr');
  location.reload();
}

async function syncLiveData(){
  const [st,pts,alts]=await Promise.all([apig('/staff'),apig('/patients'),apig('/alerts')]);
  if(st) S.staff=st.map(s=>({id:String(s.id),name:s.name,role:s.role,dept:s.department||'',emp:s.emp_id||'',color:'#00C4B4'}));
  if(pts){
    S.patients=pts.map(p=>({
      id:String(p.id),name:p.name,age:p.age,gender:p.gender,phone:p.phone||'',
      ehr:p.ehr_id||('EHR-'+p.id),diag:p.diagnosis||'',icd:p.icd_code||'',
      bed:p.bed||'',doc:String(p.doctor_id||''),nurse:String(p.nurse_id||''),
      type:p.admission_type||'',admit:p.admit_time||NOW(),status:p.status||'Active',
      cc:p.chief_complaint||'',allergy:p.allergies||'None Known',bg:p.blood_group||'',
    }));
    S.patients.forEach(p=>{
      if(!S.vitals[p.id]) S.vitals[p.id]=[];
      if(!S.rx[p.id]) S.rx[p.id]=[];
      if(!S.labs[p.id]) S.labs[p.id]=[];
      if(!S.cn[p.id]) S.cn[p.id]=[];
      if(!S.nn[p.id]) S.nn[p.id]=[];
      if(!S.chat[p.id]) S.chat[p.id]=[];
      if(!S.mar[p.id]) S.mar[p.id]=[];
    });
  }
  if(alts) S.alerts=alts.map(a=>({id:String(a.id),pid:String(a.patient_id),type:a.type||'info',title:a.title||'Alert',msg:a.message||'',t:a.created_at?new Date(a.created_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}):'',acked:!!a.acknowledged_by}));
}

async function loadPatientData(id){
  if(!IS_LIVE) return;
  const [v,rx,labs,cn,nn,chat,mar]=await Promise.all([
    apig('/vitals/'+id),apig('/prescriptions/'+id),apig('/labs/'+id),
    apig('/notes/consult/'+id),apig('/notes/nursing/'+id),
    apig('/chat/'+id),apig('/mar/'+id),
  ]);
  const mapV=v=>v?v.map(x=>({id:String(x.id),t:new Date(x.recorded_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}),bps:x.bp_sys,bpd:x.bp_dia,pr:x.pulse,sp:x.spo2,tmp:x.temperature,rr:x.resp_rate,gcs:x.gcs,uo:x.urine_output,gl:x.blood_glucose,pa:x.pain_score,nt:x.notes,by:x.recorded_by_name||'Staff'})):null;
  if(v) S.vitals[id]=mapV(v);
  if(rx) S.rx[id]=rx.map(x=>({id:String(x.id),drug:x.drug,dose:x.dose,route:x.route,freq:x.frequency,dur:x.duration,inst:x.instructions||'',by:x.prescribed_by_name||'Doctor',t:new Date(x.created_at).toLocaleString('en-IN'),status:x.status}));
  if(labs) S.labs[id]=labs.map(x=>({id:String(x.id),test:x.test_name,cat:x.category||'',pri:x.priority,status:x.status,result:x.result||'',rs:x.result_status||'',by:x.ordered_by_name||'Doctor',t:new Date(x.created_at).toLocaleString('en-IN')}));
  if(cn) S.cn[id]=cn.map(x=>({id:String(x.id),t:new Date(x.created_at).toLocaleString('en-IN'),by:x.written_by_name||'Doctor',s:x.subjective,o:x.objective,a:x.assessment,p:x.plan}));
  if(nn) S.nn[id]=nn.map(x=>({id:String(x.id),t:new Date(x.created_at).toLocaleString('en-IN'),by:x.written_by_name||'Nurse',note:x.note}));
  if(chat) S.chat[id]=chat.map(x=>({from:x.sender_role,name:x.sender_name,msg:x.message,t:new Date(x.sent_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}));
  if(mar) S.mar[id]=mar.map(x=>({id:String(x.id),rxId:String(x.prescription_id),status:x.status,by:x.by_name||'Nurse',t:new Date(x.administered_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}),drug:x.drug}));
  render();
}

