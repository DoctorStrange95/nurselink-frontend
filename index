async function recordMAR(pid, rxId, status) {
  if (!S.mar[pid]) S.mar[pid] = [];
  const rx = (S.prescriptions[pid]||[]).find(r=>r.id===rxId);
  S.mar[pid].unshift({ id:'M'+Date.now(), rxId, status, by:getCurrentStaffName(), time:ts() });
  if (status === 'Not Available') {
    S.notifications.unshift({ id:'N'+Date.now(), role:'Pharmacist', title:'Drug Not Available', body:`${S.patients.find(p=>p.id===pid)?.name} — ${rx?.drug} not available on ward`, time:ts(), read:false });
    showToast(`Pharmacy alerted: ${rx?.drug} not available`, 'warn');
  } else {
    showToast(`${rx?.drug}: Marked as ${status}`);
  }
  if (IS_LIVE) await apiPost('/mar', { prescription_id: rxId, patient_id: pid, status });
  save();
