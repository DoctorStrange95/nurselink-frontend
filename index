function submitAddStaff() {
  const name = document.getElementById('sf-name').value.trim();
  const role = document.getElementById('sf-role').value;
  const dept = document.getElementById('sf-dept').value.trim() || 'General';
  const empId = document.getElementById('sf-emp').value.trim() || role[0]+'-'+Math.floor(100+Math.random()*900);
  if (!name) { alert('Name required'); return; }
  S.staff.push({ id:'S'+Date.now(), name, role, dept, empId, color:'#546E7A' });
  closeModal();
  showToast(`${name} added as ${role}`);
  save();
}

