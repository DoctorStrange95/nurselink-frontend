<script>
// ============================================================
// API LAYER — connects to nurselink-server.onrender.com
// ============================================================
const API_BASE = 'https://nurselink-server.onrender.com/api';
let API_TOKEN = null;
let IS_LIVE = false;

async function apiGet(path) {
  if (!API_TOKEN) return null;
  try {
    const res = await fetch(API_BASE + path, {
      headers: { 'Authorization': 'Bearer ' + API_TOKEN }
    });
    if (!res.ok) return null;
    return await res.json();
  } catch(e) { return null; }
}

async function apiPost(path, body) {
  if (!API_TOKEN) return null;
  try {
    const res = await fetch(API_BASE + path, {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + API_TOKEN, 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    if (!res.ok) return null;
    return await res.json();
  } catch(e) { return null; }
}

async function apiPatch(path, body) {
  if (!API_TOKEN) return null;
  try {
    const res = await fetch(API_BASE + path, {
      method: 'PATCH',
      headers: { 'Authorization': 'Bearer ' + API_TOKEN, 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    if (!res.ok) return null;
    return await res.json();
  } catch(e) { return null; }
}

// ============================================================
// STARTUP — show login or app
// ============================================================
async function startup() {
  // Check if server is reachable
  const statusEl = document.getElementById('login-server-status');
  try {
    const res = await fetch(API_BASE + '/health', { signal: AbortSignal.timeout(5000) });
    if (res.ok) {
      statusEl.innerHTML = '<span style="color:#2E7D32">● Server online</span>';
    } else {
      statusEl.innerHTML = '<span style="color:#F57C00">⚠ Server reachable, auth required</span>';
    }
  } catch(e) {
    statusEl.innerHTML = '<span style="color:#546E7A">● Server offline — demo mode available</span>';
  }

  // Check saved token
  const saved = localStorage.getItem('NL_JWT');
  if (saved) {
    API_TOKEN = saved;
    try {
      const payload = JSON.parse(atob(API_TOKEN.split('.')[1]));
      window._loggedInUser = payload;
      if (payload.role) S.currentRole = payload.role;
    } catch(e) {}
    const ok = await tryLoadLiveData();
    if (ok) { showApp(true); return; }
    API_TOKEN = null;
    localStorage.removeItem('NL_JWT');
  }

  // Show login
  document.getElementById('login-screen').style.display = 'flex';
}

async function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pwd = document.getElementById('login-password').value;
  const btn = document.getElementById('login-btn');
  const err = document.getElementById('login-error');
  err.style.display = 'none';
  btn.textContent = 'Signing in...';
  btn.disabled = true;

  try {
    const res = await fetch(API_BASE + '/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password: pwd })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || data.message || 'Login failed');
    API_TOKEN = data.token;
    localStorage.setItem('NL_JWT', API_TOKEN);
    // Decode user from token payload
    try {
      const payload = JSON.parse(atob(API_TOKEN.split('.')[1]));
      window._loggedInUser = payload;
      if (payload.role) S.currentRole = payload.role;
    } catch(e) {}
    await tryLoadLiveData();
    showApp(true);
  } catch(e) {
    err.textContent = e.message || 'Could not connect to server.';
    err.style.display = 'block';
    btn.textContent = 'Sign In';
    btn.disabled = false;
  }
}

async function tryLoadLiveData() {
  const [staffRes, patientsRes, alertsRes] = await Promise.all([
    apiGet('/staff'),
    apiGet('/patients'),
    apiGet('/alerts')
  ]);
  if (!staffRes && !patientsRes) return false;

  IS_LIVE = true;

  // Map backend data into app state
  if (staffRes && Array.isArray(staffRes)) {
    const colorMap = { Doctor:'#00B4A6', Nurse:'#5C6BC0', Pharmacist:'#2E7D32', 'Lab Tech':'#F57C00', Admin:'#546E7A' };
    S.staff = staffRes.map(s => ({
      id: String(s.id),
      name: s.name,
      role: s.role,
      dept: s.department || s.dept || '',
      empId: s.emp_id || s.empId || '',
      color: colorMap[s.role] || '#546E7A'
    }));
  }

  if (patientsRes && Array.isArray(patientsRes)) {
    S.patients = patientsRes.map(p => ({
      id: String(p.id),
      name: p.name,
      age: p.age || '',
      gender: p.gender || '',
      phone: p.phone || '',
      ehrId: p.ehr_id || p.ehrId || ('EHR-' + p.id),
      diagnosis: p.diagnosis || '',
      icd: p.icd || '',
      bed: p.bed || '',
      doctorId: String(p.doctor_id || p.doctorId || ''),
      nurseId: String(p.nurse_id || p.nurseId || ''),
      admissionType: p.admission_type || p.admissionType || '',
      admitTime: p.admit_time || p.admitTime || '',
      status: p.status || 'Active',
      chiefComplaint: p.chief_complaint || p.chiefComplaint || '',
      allergies: p.allergies || '',
      bloodGroup: p.blood_group || p.bloodGroup || ''
    }));
    // Init empty sub-records for new patients
    S.patients.forEach(p => {
      if (!S.vitals[p.id]) S.vitals[p.id] = [];
      if (!S.prescriptions[p.id]) S.prescriptions[p.id] = [];
      if (!S.labOrders[p.id]) S.labOrders[p.id] = [];
      if (!S.consultNotes[p.id]) S.consultNotes[p.id] = [];
      if (!S.nursingNotes[p.id]) S.nursingNotes[p.id] = [];
      if (!S.chat[p.id]) S.chat[p.id] = [];
    });
  }

  if (alertsRes && Array.isArray(alertsRes)) {
    const liveAlerts = alertsRes.map(a => ({
      id: String(a.id),
      patientId: String(a.patient_id || a.patientId),
      type: a.type || 'info',
      title: a.title || a.alert_type || 'Alert',
      msg: a.message || a.msg || '',
      time: a.created_at ? new Date(a.created_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) : '',
      acked: !!a.acknowledged_by
    }));
    if (liveAlerts.length > 0) S.alerts = liveAlerts;
  }

  return true;
}

function demoMode() {
  IS_LIVE = false;
  showApp(false);
}

let socket = null;

function showApp(live) {
  IS_LIVE = live;
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').style.display = 'flex';
  document.getElementById('demo-badge').style.display = live ? 'none' : 'block';
  document.getElementById('live-badge').style.display = live ? 'block' : 'none';
  document.getElementById('offline-badge').style.display = 'none';
  document.getElementById('refresh-btn').style.display = live ? 'inline-block' : 'none';
  if (live) {
    showToast('Connected to live server ✓', 'info');
    connectSocket();
  }
  renderAll();
}

function connectSocket() {
  if (!IS_LIVE) return;
  const script = document.createElement('script');
  script.src = 'https://cdn.jsdelivr.net/npm/socket.io-client@4/dist/socket.io.min.js';
  script.onload = () => {
    socket = io('https://nurselink-server.onrender.com');
    socket.on('vitals:new', v => {
      const pid = String(v.patient_id);
      if (!S.vitals[pid]) S.vitals[pid] = [];
      S.vitals[pid].unshift({ id:String(v.id), time:new Date(v.recorded_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}), bpSys:v.bp_sys, bpDia:v.bp_dia, pulse:v.pulse, spo2:v.spo2, temp:v.temperature, rr:v.resp_rate, gcs:v.gcs, uo:v.urine_output, glucose:v.blood_glucose, drain:v.drain_output, pain:v.pain_score, notes:v.notes, nurse:v.recorded_by_name||'Staff' });
      renderAll();
    });
    socket.on('alert:new', data => {
      data.alerts.forEach(a => {
        S.alerts.unshift({ id:'A'+Date.now()+Math.random(), patientId:String(data.patientId), type:a.type, title:a.title, msg:a.message||'', time:ts(), acked:false });
        showToast(`${a.title}`, a.type==='critical'?'error':'warn');
      });
      renderAll();
    });
    socket.on('prescription:new', rx => {
      const pid = String(rx.patient_id);
      if (!S.prescriptions[pid]) S.prescriptions[pid] = [];
      S.prescriptions[pid].unshift({ id:String(rx.id), drug:rx.drug, dose:rx.dose, route:rx.route, freq:rx.frequency, duration:rx.duration, instructions:rx.instructions, prescribedBy:rx.prescribed_by_name||'Doctor', time:new Date(rx.created_at).toLocaleString('en-IN'), status:rx.status });
      renderAll();
    });
    socket.on('chat:message', msg => {
      const pid = String(msg.patient_id);
      if (!S.chat[pid]) S.chat[pid] = [];
      S.chat[pid].push({ from:msg.sender_role, name:msg.sender_name, msg:msg.message, time:new Date(msg.sent_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) });
      renderAll();
    });
    socket.on('patient:admitted', p => { refreshLiveData(); });
  };
  document.head.appendChild(script);
}

async function loadPatientData(pid) {
  if (!IS_LIVE) return;
  const [vitals, rx, labs, consult, nursing, chat] = await Promise.all([
    apiGet('/vitals/' + pid),
    apiGet('/prescriptions/' + pid),
    apiGet('/labs/' + pid),
    apiGet('/notes/consult/' + pid),
    apiGet('/notes/nursing/' + pid),
    apiGet('/chat/' + pid),
  ]);
  if (vitals) S.vitals[pid] = vitals.map(v=>({ id:String(v.id), time:new Date(v.recorded_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})+' '+new Date(v.recorded_at).toLocaleDateString('en-IN'), bpSys:v.bp_sys, bpDia:v.bp_dia, pulse:v.pulse, spo2:v.spo2, temp:v.temperature, rr:v.resp_rate, gcs:v.gcs, uo:v.urine_output, glucose:v.blood_glucose, drain:v.drain_output, pain:v.pain_score, notes:v.notes, nurse:v.recorded_by_name||'Staff' }));
  if (rx) S.prescriptions[pid] = rx.map(r=>({ id:String(r.id), drug:r.drug, dose:r.dose, route:r.route, freq:r.frequency, duration:r.duration, instructions:r.instructions, prescribedBy:r.prescribed_by_name||'Doctor', time:new Date(r.created_at).toLocaleString('en-IN'), status:r.status }));
  if (labs) S.labOrders[pid] = labs.map(l=>({ id:String(l.id), test:l.test_name, category:l.category, priority:l.priority, status:l.status, result:l.result||'', resultStatus:l.result_status||'', orderedBy:l.ordered_by_name||'Doctor', time:new Date(l.created_at).toLocaleString('en-IN') }));
  if (consult) S.consultNotes[pid] = consult.map(c=>({ id:String(c.id), time:new Date(c.created_at).toLocaleString('en-IN'), by:c.written_by_name||'Doctor', subjective:c.subjective, objective:c.objective, assessment:c.assessment, plan:c.plan }));
  if (nursing) S.nursingNotes[pid] = nursing.map(n=>({ id:String(n.id), time:new Date(n.created_at).toLocaleString('en-IN'), by:n.written_by_name||'Nurse', note:n.note }));
  if (chat) S.chat[pid] = chat.map(m=>({ from:m.sender_role, name:m.sender_name, msg:m.message, time:new Date(m.sent_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) }));
  if (socket) socket.emit('join:patient', pid);
  renderAll();
}

async function refreshLiveData() {
  const btn = document.getElementById('refresh-btn');
  btn.textContent = '↻ Syncing...';
  btn.disabled = true;
  const ok = await tryLoadLiveData();
  btn.textContent = '↻ Refresh';
  btn.disabled = false;
  if (ok) { showToast('Data refreshed from server ✓', 'info'); renderAll(); }
  else showToast('Sync failed — showing local data', 'warn');
}

function logout() {
  localStorage.removeItem('NL_JWT');
  API_TOKEN = null;
  IS_LIVE = false;
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('login-error').style.display = 'none';
  document.getElementById('login-btn').textContent = 'Sign In';
  document.getElementById('login-btn').disabled = false;
}

// Wire up Enter key on login
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('login-password')?.addEventListener('keydown', e => {
    if (e.key === 'Enter') doLogin();
  });
  startup();
});

