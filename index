function triggerSOS(pid) {
  if (!confirm(`Send SOS for ${S.patients.find(p=>p.id===pid)?.name}?`)) return;
  const p = S.patients.find(x=>x.id===pid);
  const vitals = (S.vitals[pid]||[])[0];
  S.sosActive = true;
  S.sosPatientId = pid;
  const overlay = document.getElementById('sos-overlay');
  overlay.style.display = 'flex';
  document.getElementById('sos-patient-name').textContent = `${p.name} | Bed ${p.bed}`;
  document.getElementById('sos-details').innerHTML = vitals
    ? `BP: ${vitals.bpSys}/${vitals.bpDia} | SpO₂: ${vitals.spo2}% | Pulse: ${vitals.pulse}\nUO: ${vitals.uo} ml/hr | Temp: ${vitals.temp}°C\nNurse: ${vitals.nurse} | ${vitals.time}`
    : 'No vitals on record\nNurse: ' + getCurrentStaffName();
  document.getElementById('sos-ack-note').textContent = 'Switch to Doctor role to acknowledge';
  S.alerts.unshift({ id:'SOS'+Date.now(), patientId:pid, type:'critical', title:'SOS ALERT', msg:`Manual SOS by ${getCurrentStaffName()}`, time:ts(), acked:false });
  S.notifications.unshift({ id:'N'+Date.now(), role:'Doctor', title:'🚨 SOS ALERT', body:`${p.name} — Manual SOS from ${getCurrentStaffName()}`, time:ts(), read:false });
  save();
}

function acknowledgeSOS() {
  if (S.currentRole !== 'Doctor') {
    showToast('Only Doctor can acknowledge SOS', 'error');
    return;
  }
  document.getElementById('sos-overlay').style.display = 'none';
  const pid = S.sosPatientId;
  S.sosActive = false;
  const p = S.patients.find(x=>x.id===pid);
  showToast(`SOS acknowledged for ${p?.name}`);
  S.alerts.filter(a=>a.title==='SOS ALERT'&&a.patientId===pid).forEach(a=>a.acked=true);
  save();
}

