async function finalizeDischargeSummary(pid) {
  const p = S.patients.find(x=>x.id===pid);
  const cond = document.getElementById('ds-cond')?.value || 'Stable';
  p.status = 'Discharged';
  p.dischargeTime = now();
  p.dischargeCondition = cond;
  S.dischargeReady[pid] = false;
  const bed = S.beds.find(b=>b.id===p.bed);
  if (bed) bed.status = 'available';
  S.notifications.unshift({ id:'N'+Date.now(), role:'Nurse', title:'Patient Discharged', body:`${p.name} discharged — Condition: ${cond}`, time:ts(), read:false });
  closeModal();
  if (IS_LIVE) await apiPatch('/patients/' + pid + '/discharge', { condition: cond });
  showToast(`${p.name} discharged. Condition: ${cond}`);
  save();
}

