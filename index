<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NurseLink IPD — Clinical Coordination, Unified</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0A1628;
  --navy-light: #112240;
  --panel: #F0F4F8;
  --white: #FFFFFF;
  --teal: #00B4A6;
  --teal-dark: #008F84;
  --indigo: #5C6BC0;
  --emerald: #2E7D32;
  --amber: #F57C00;
  --red: #C62828;
  --red-light: #FFEBEE;
  --slate: #546E7A;
  --text: #1A2332;
  --text-muted: #64748B;
  --border: #CBD5E1;
  --success: #2E7D32;
  --warn: #E65100;
  --critical: #B71C1C;
  --shadow: 0 2px 12px rgba(0,0,0,0.08);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.14);
  --role-color: var(--teal);
  --font: 'DM Sans', sans-serif;
  --mono: 'IBM Plex Mono', monospace;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--font); background: var(--panel); color: var(--text); min-height: 100vh; }

/* TOPBAR */
#topbar {
  background: var(--navy);
  color: white;
  display: flex;
  align-items: center;
  padding: 0 20px;
  height: 56px;
  position: sticky;
  top: 0;
  z-index: 100;
  gap: 16px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.3);
}
#topbar .logo { font-size: 18px; font-weight: 700; color: var(--teal); letter-spacing: -0.5px; flex: 1; }
#topbar .logo span { color: white; font-weight: 300; }
#role-switcher { display: flex; gap: 6px; }
#role-switcher button {
  padding: 5px 12px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.2);
  background: transparent; color: rgba(255,255,255,0.7); font-size: 12px; cursor: pointer;
  font-family: var(--font); transition: all 0.15s;
}
#role-switcher button.active { background: var(--role-color); border-color: var(--role-color); color: white; font-weight: 600; }
#notif-btn {
  background: none; border: none; color: white; cursor: pointer; position: relative;
  font-size: 18px; padding: 4px 8px;
}
#notif-badge {
  position: absolute; top: 0; right: 0; background: var(--red);
  color: white; font-size: 10px; font-weight: 700; border-radius: 10px;
  padding: 1px 5px; min-width: 16px; text-align: center;
}
#clock { font-family: var(--mono); font-size: 12px; color: rgba(255,255,255,0.5); white-space: nowrap; }
#demo-badge { background: var(--amber); color: white; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 3px; }

/* LAYOUT */
#app { display: flex; height: calc(100vh - 56px); }
#sidebar {
  width: 220px; background: var(--navy-light); color: white;
  display: flex; flex-direction: column; padding: 16px 0; flex-shrink: 0;
  border-right: 1px solid rgba(255,255,255,0.06);
}
#sidebar .nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 20px; cursor: pointer; font-size: 13px; font-weight: 500;
  color: rgba(255,255,255,0.6); transition: all 0.15s; border-left: 3px solid transparent;
}
#sidebar .nav-item:hover { color: white; background: rgba(255,255,255,0.05); }
#sidebar .nav-item.active { color: white; background: rgba(0,180,166,0.15); border-left-color: var(--teal); }
#sidebar .nav-section { font-size: 10px; font-weight: 700; color: rgba(255,255,255,0.3); padding: 16px 20px 6px; letter-spacing: 1px; text-transform: uppercase; }
#sidebar .user-info { margin-top: auto; padding: 16px 20px; border-top: 1px solid rgba(255,255,255,0.08); }
#sidebar .user-name { font-size: 13px; font-weight: 600; }
#sidebar .user-role { font-size: 11px; color: rgba(255,255,255,0.4); }

#main { flex: 1; overflow-y: auto; padding: 24px; }
#right-panel {
  width: 300px; background: white; border-left: 1px solid var(--border);
  display: flex; flex-direction: column; flex-shrink: 0;
}
#right-panel .rp-header { padding: 16px; border-bottom: 1px solid var(--border); font-weight: 600; font-size: 13px; }
#alert-feed { flex: 1; overflow-y: auto; padding: 8px; }

/* CARDS */
.card { background: white; border-radius: 10px; box-shadow: var(--shadow); overflow: hidden; }
.card-header { padding: 14px 16px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
.card-header h3 { font-size: 14px; font-weight: 600; }
.card-body { padding: 16px; }

/* PATIENT CARDS */
.patient-card {
  background: white; border-radius: 10px; box-shadow: var(--shadow);
  border: 1px solid var(--border); overflow: hidden; cursor: pointer; transition: all 0.15s;
}
.patient-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); }
.patient-card-header { padding: 12px 16px; background: var(--navy); color: white; }
.patient-card-header .pt-name { font-weight: 700; font-size: 15px; }
.patient-card-header .pt-meta { font-size: 11px; color: rgba(255,255,255,0.6); margin-top: 2px; }
.patient-card-body { padding: 12px 16px; }
.pt-info-row { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
.pt-info-row span:last-child { font-weight: 600; color: var(--text); }
.vital-pill { display: inline-flex; align-items: center; gap: 4px; background: var(--panel); border-radius: 20px; padding: 2px 8px; font-size: 11px; font-family: var(--mono); }
.vital-pill.warn { background: #FFF3E0; color: var(--warn); }
.vital-pill.critical { background: var(--red-light); color: var(--red); font-weight: 700; }
.badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
.badge-teal { background: #E0F7FA; color: #00838F; }
.badge-red { background: var(--red-light); color: var(--red); }
.badge-green { background: #E8F5E9; color: var(--emerald); }
.badge-amber { background: #FFF3E0; color: var(--amber); }
.badge-indigo { background: #E8EAF6; color: var(--indigo); }

/* BUTTONS */
.btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 7px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; transition: all 0.15s; font-family: var(--font); }
.btn-primary { background: var(--teal); color: white; }
.btn-primary:hover { background: var(--teal-dark); }
.btn-danger { background: var(--red); color: white; }
.btn-danger:hover { background: #8B0000; }
.btn-outline { background: transparent; border: 1.5px solid var(--border); color: var(--text); }
.btn-outline:hover { border-color: var(--teal); color: var(--teal); }
.btn-sm { padding: 5px 10px; font-size: 12px; }
.btn-warn { background: var(--amber); color: white; }
.btn-success { background: var(--emerald); color: white; }
.btn-ghost { background: rgba(255,255,255,0.1); color: white; }

/* TABS */
.tabs { display: flex; border-bottom: 2px solid var(--border); margin-bottom: 20px; gap: 2px; }
.tab { padding: 8px 16px; font-size: 13px; font-weight: 500; cursor: pointer; color: var(--text-muted); border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all 0.15s; }
.tab.active { color: var(--teal); border-bottom-color: var(--teal); font-weight: 700; }
.tab-content { display: none; }
.tab-content.active { display: block; }

/* FORMS */
.form-group { margin-bottom: 14px; }
.form-label { display: block; font-size: 12px; font-weight: 600; color: var(--text-muted); margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px; }
.form-control {
  width: 100%; padding: 9px 12px; border: 1.5px solid var(--border);
  border-radius: 7px; font-size: 13px; font-family: var(--font);
  transition: border-color 0.15s; background: white;
}
.form-control:focus { outline: none; border-color: var(--teal); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

/* TABLE */
.data-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.data-table th { background: var(--panel); padding: 8px 12px; text-align: left; font-weight: 700; font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.data-table td { padding: 9px 12px; border-bottom: 1px solid var(--border); vertical-align: middle; }
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td { background: var(--panel); }
.mono { font-family: var(--mono); font-size: 12px; }
.critical-val { color: var(--red); font-weight: 700; }
.warn-val { color: var(--warn); font-weight: 700; }
.normal-val { color: var(--success); }

/* MODAL */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(10,22,40,0.75); z-index: 200;
  display: flex; align-items: center; justify-content: center; padding: 20px;
}
.modal { background: white; border-radius: 12px; max-width: 600px; width: 100%; max-height: 85vh; overflow-y: auto; box-shadow: var(--shadow-lg); }
.modal-header { padding: 18px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
.modal-header h2 { font-size: 16px; font-weight: 700; }
.modal-close { background: none; border: none; font-size: 20px; cursor: pointer; color: var(--text-muted); line-height: 1; }
.modal-body { padding: 20px; }
.modal-footer { padding: 16px 20px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 10px; }

/* SOS OVERLAY */
#sos-overlay {
  position: fixed; inset: 0; background: var(--red); z-index: 999;
  display: none; flex-direction: column; align-items: center; justify-content: center;
  color: white; text-align: center; animation: pulse-bg 1s infinite;
}
@keyframes pulse-bg { 0%,100% { background: #C62828; } 50% { background: #B71C1C; } }
#sos-overlay .sos-title { font-size: 48px; font-weight: 900; letter-spacing: -2px; }
#sos-overlay .sos-patient { font-size: 24px; margin-top: 8px; opacity: 0.9; }
#sos-overlay .sos-details { font-family: var(--mono); font-size: 14px; margin-top: 16px; opacity: 0.8; line-height: 1.8; }

/* ALERT ITEMS */
.alert-item { padding: 10px; border-radius: 8px; margin-bottom: 8px; font-size: 12px; border-left: 3px solid; }
.alert-item.critical { background: #FFEBEE; border-color: var(--red); }
.alert-item.warning { background: #FFF3E0; border-color: var(--amber); }
.alert-item.info { background: #E3F2FD; border-color: #1976D2; }
.alert-item .al-title { font-weight: 700; }
.alert-item .al-meta { color: var(--text-muted); margin-top: 2px; }

/* MAR */
.mar-row { display: flex; align-items: center; gap: 10px; padding: 10px; border: 1px solid var(--border); border-radius: 8px; margin-bottom: 8px; }
.mar-drug { flex: 1; }
.mar-drug-name { font-weight: 600; font-size: 13px; }
.mar-drug-dose { font-size: 12px; color: var(--text-muted); font-family: var(--mono); }
.mar-actions { display: flex; gap: 6px; flex-wrap: wrap; }
.mar-btn { padding: 4px 10px; font-size: 11px; font-weight: 600; border-radius: 5px; border: 1.5px solid; cursor: pointer; font-family: var(--font); transition: all 0.1s; }
.mar-btn.given { border-color: var(--emerald); color: var(--emerald); background: white; }
.mar-btn.given:hover, .mar-btn.given.active { background: var(--emerald); color: white; }
.mar-btn.held { border-color: var(--amber); color: var(--amber); background: white; }
.mar-btn.held:hover, .mar-btn.held.active { background: var(--amber); color: white; }
.mar-btn.refused { border-color: var(--slate); color: var(--slate); background: white; }
.mar-btn.refused:hover, .mar-btn.refused.active { background: var(--slate); color: white; }
.mar-btn.na { border-color: var(--red); color: var(--red); background: white; }
.mar-btn.na:hover, .mar-btn.na.active { background: var(--red); color: white; }
.mar-log-entry { font-size: 11px; color: var(--text-muted); font-family: var(--mono); padding: 3px 6px; background: var(--panel); border-radius: 4px; margin-top: 4px; }
.drug-dc { text-decoration: line-through; color: var(--text-muted); }

/* VITALS TREND */
.vitals-trend { display: flex; align-items: flex-end; gap: 3px; height: 40px; padding: 4px; background: var(--panel); border-radius: 6px; }
.trend-bar { width: 8px; border-radius: 2px 2px 0 0; transition: height 0.3s; min-height: 4px; }

/* CHAT */
.chat-area { height: 280px; overflow-y: auto; padding: 10px; background: var(--panel); border-radius: 8px; margin-bottom: 10px; }
.chat-msg { margin-bottom: 10px; }
.chat-msg.sent { text-align: right; }
.chat-bubble { display: inline-block; padding: 8px 12px; border-radius: 12px; font-size: 12px; max-width: 85%; text-align: left; }
.chat-msg.received .chat-bubble { background: white; border: 1px solid var(--border); }
.chat-msg.sent .chat-bubble { background: var(--teal); color: white; }
.chat-meta { font-size: 10px; color: var(--text-muted); margin-top: 2px; }

/* SECTION TITLE */
.section-title { font-size: 20px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
.section-sub { font-size: 13px; color: var(--text-muted); margin-bottom: 20px; }

/* GRID */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
.patient-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }

/* VITALS SUMMARY */
.vitals-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
.vital-box { background: var(--panel); border-radius: 8px; padding: 12px; text-align: center; border: 1.5px solid transparent; }
.vital-box.critical-box { background: var(--red-light); border-color: var(--red); }
.vital-box.warn-box { background: #FFF3E0; border-color: var(--amber); }
.vital-box .vb-label { font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.vital-box .vb-value { font-size: 22px; font-weight: 700; font-family: var(--mono); margin-top: 4px; }
.vital-box .vb-unit { font-size: 10px; color: var(--text-muted); }

/* NOTIFICATION DROPDOWN */
#notif-dropdown {
  position: fixed; top: 56px; right: 0; width: 320px; background: white;
  border: 1px solid var(--border); border-radius: 0 0 10px 10px; box-shadow: var(--shadow-lg);
  z-index: 150; max-height: 400px; overflow-y: auto; display: none;
}
.notif-item { padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 12px; cursor: pointer; }
.notif-item:hover { background: var(--panel); }
.notif-item .ni-title { font-weight: 700; }
.notif-item .ni-body { color: var(--text-muted); margin-top: 2px; }
.notif-item .ni-time { font-size: 10px; color: var(--text-muted); font-family: var(--mono); margin-top: 3px; }

/* DISCHARGE */
.discharge-section { border: 1px solid var(--border); border-radius: 8px; overflow: hidden; margin-bottom: 10px; }
.discharge-section-header { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; background: var(--panel); font-size: 13px; font-weight: 600; }
.discharge-section-body { padding: 12px 14px; font-size: 12px; line-height: 1.6; }
.toggle-switch { position: relative; width: 36px; height: 20px; }
.toggle-switch input { opacity: 0; width: 0; height: 0; }
.toggle-slider { position: absolute; inset: 0; background: #CBD5E1; border-radius: 20px; cursor: pointer; transition: 0.2s; }
.toggle-slider:before { content: ''; position: absolute; height: 14px; width: 14px; left: 3px; bottom: 3px; background: white; border-radius: 50%; transition: 0.2s; }
.toggle-switch input:checked + .toggle-slider { background: var(--teal); }
.toggle-switch input:checked + .toggle-slider:before { transform: translateX(16px); }

/* WORKLOAD BAR */
.workload-bar { height: 8px; background: var(--panel); border-radius: 4px; overflow: hidden; margin-top: 4px; }
.workload-fill { height: 100%; background: var(--teal); border-radius: 4px; transition: width 0.3s; }
.workload-fill.high { background: var(--red); }
.workload-fill.med { background: var(--amber); }

/* INTEGRATION PAYLOAD */
.payload-link { font-size: 11px; color: var(--teal); cursor: pointer; font-family: var(--mono); }
.payload-link:hover { text-decoration: underline; }
.payload-code { background: #1E1E2E; color: #A9B1D6; font-family: var(--mono); font-size: 12px; padding: 16px; border-radius: 8px; white-space: pre; overflow-x: auto; line-height: 1.6; }

/* PHARMACY */
.rx-item { border: 1px solid var(--border); border-radius: 8px; padding: 12px; margin-bottom: 8px; }
.rx-item-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.rx-drug-name { font-weight: 700; font-size: 14px; }
.rx-drug-meta { font-size: 12px; color: var(--text-muted); font-family: var(--mono); }
.rx-status { font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 10px; }
.rx-status.pending { background: #FFF3E0; color: var(--amber); }
.rx-status.dispensed { background: #E8F5E9; color: var(--emerald); }
.rx-status.oos { background: var(--red-light); color: var(--red); }

/* LAB */
.lab-test-item { border: 1px solid var(--border); border-radius: 8px; padding: 10px 14px; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; }
.lab-test-name { flex: 1; font-weight: 600; font-size: 13px; }
.lab-priority { font-size: 11px; padding: 2px 8px; border-radius: 10px; font-weight: 700; }
.lab-priority.stat { background: var(--red-light); color: var(--red); }
.lab-priority.urgent { background: #FFF3E0; color: var(--amber); }
.lab-priority.routine { background: var(--panel); color: var(--text-muted); }
.lab-status { font-size: 11px; font-weight: 700; }
.lab-result-value { font-family: var(--mono); font-size: 13px; }

/* ADMIN */
.staff-row { display: flex; align-items: center; gap: 12px; padding: 10px 14px; border-bottom: 1px solid var(--border); }
.staff-avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; color: white; flex-shrink: 0; }
.staff-info { flex: 1; }
.staff-name { font-weight: 600; font-size: 13px; }
.staff-dept { font-size: 11px; color: var(--text-muted); }
.staff-link { font-size: 11px; color: var(--teal); font-family: var(--mono); }

/* TOAST */
#toast-container { position: fixed; top: 70px; right: 16px; z-index: 300; display: flex; flex-direction: column; gap: 8px; }
.toast { background: var(--navy); color: white; padding: 12px 16px; border-radius: 8px; font-size: 13px; box-shadow: var(--shadow-lg); max-width: 300px; border-left: 4px solid var(--teal); animation: slideIn 0.3s ease; }
.toast.error { border-left-color: var(--red); }
.toast.warn { border-left-color: var(--amber); }
@keyframes slideIn { from { transform: translateX(320px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

/* SCROLLBAR */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

/* UTIL */
.flex { display: flex; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.gap-2 { gap: 8px; }
.gap-3 { gap: 12px; }
.gap-4 { gap: 16px; }
.mt-2 { margin-top: 8px; }
.mt-4 { margin-top: 16px; }
.mb-2 { margin-bottom: 8px; }
.mb-4 { margin-bottom: 16px; }
.text-muted { color: var(--text-muted); font-size: 12px; }
.text-sm { font-size: 12px; }
.fw-600 { font-weight: 600; }
.w-full { width: 100%; }
hr.divider { border: none; border-top: 1px solid var(--border); margin: 16px 0; }

@media (max-width: 900px) {
  #sidebar { display: none; }
  #right-panel { display: none; }
  .vitals-grid { grid-template-columns: repeat(2, 1fr); }
  .form-row, .form-row-3 { grid-template-columns: 1fr; }
  .grid-2, .grid-3 { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<!-- TOPBAR -->
<div id="topbar">
  <div class="logo">NurseLink<span> IPD</span></div>
  <div id="role-switcher"></div>
  <div id="demo-badge" style="display:none">DEMO</div>
  <div id="live-badge" style="background:#2E7D32;color:white;font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;display:none">● LIVE</div>
  <div id="offline-badge" style="background:#546E7A;color:white;font-size:10px;font-weight:700;padding:2px 8px;border-radius:3px;display:none">OFFLINE</div>
  <button id="refresh-btn" onclick="refreshLiveData()" title="Refresh from server" style="display:none;background:none;border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.7);font-size:12px;padding:4px 10px;border-radius:5px;cursor:pointer;font-family:var(--font);">↻ Refresh</button>
  <button id="notif-btn" onclick="toggleNotif()">🔔<span id="notif-badge" class="hidden">0</span></button>
  <div id="clock"></div>
</div>

<!-- NOTIFICATION DROPDOWN -->
<div id="notif-dropdown"></div>

<!-- LOGIN SCREEN -->
<div id="login-screen" style="display:none;position:fixed;inset:0;background:var(--navy);z-index:500;align-items:center;justify-content:center;">
  <div style="background:white;border-radius:16px;padding:40px;width:100%;max-width:400px;box-shadow:0 20px 60px rgba(0,0,0,0.4);">
    <div style="text-align:center;margin-bottom:32px;">
      <div style="font-size:28px;font-weight:800;color:var(--navy);letter-spacing:-1px;">NurseLink<span style="color:var(--teal);font-weight:300"> IPD</span></div>
