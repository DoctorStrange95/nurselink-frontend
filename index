async function sendChat(pid) {
  const input = document.getElementById(`chat-input-${pid}`);
  const msg = input?.value.trim();
  if (!msg) return;
  if (!S.chat[pid]) S.chat[pid] = [];
  const role = S.currentRole;
  const name = getCurrentStaffName();
  S.chat[pid].push({ from:role, name, msg, time:ts() });
  const targetRole = role==='Doctor'?'Nurse':'Doctor';
  const p = S.patients.find(x=>x.id===pid);
  S.notifications.unshift({ id:'N'+Date.now(), role:targetRole, title:`Message from ${name}`, body:`Re: ${p?.name} — ${msg.substring(0,50)}`, time:ts(), read:false });
  if (input) input.value = '';
  if (IS_LIVE) await apiPost('/chat/' + pid, { message: msg });
  save();
}

