  if (!p) return;
  p.doctorId = document.getElementById('assign-doc').value;
  p.nurseId = document.getElementById('assign-nurse').value;
  const doc = S.staff.find(s=>s.id===p.doctorId);
  const nurse = S.staff.find(s=>s.id===p.nurseId);
  closeModal();
  showToast(`Care team updated — ${doc?.name}${nurse?' + '+nurse.name:''}`);
  try { localStorage.setItem('NL_STATE_V3', JSON.stringify(S)); } catch(e) {}
  renderIPDDetail(id);
}

