function loadBillPatient(pid) {
  if (!pid) { document.getElementById('bill-form').style.display='none'; return; }
  const p = S.patients.find(x=>x.id===pid);
  if (!p) return;
  document.getElementById('bill-form').style.display='block';
  // Auto-add bed charges
  window._billItems = [];
  if (p.bed && p.admitTime) {
    const los = Math.max(1, calcLOS(p.admitTime) || 1);
    window._billItems.push({ category:'Bed Charges', particulars:`Bed ${p.bed} × ${los} day(s)`, rate:2000, qty:los });
  }
  // Auto-add prescriptions as pharmacy
  (S.prescriptions[pid]||[]).filter(r=>r.status==='active').forEach(rx=>{
    window._billItems.push({ category:'Pharmacy', particulars:rx.drug+' '+rx.dose, rate:0, qty:1 });
  });
  renderBillItems();
}

function renderBillItems() {
  const tbody = document.getElementById('bill-items-body');
  if (!tbody) return;
  tbody.innerHTML = window._billItems.map((item,i)=>`
    <tr>
      <td><select class="form-control" style="font-size:12px;padding:4px" onchange="window._billItems[${i}].category=this.value;recalcBill()">
        ${['Bed Charges','Doctor Charges','Pathology','Radiology','Pharmacy','Medical Consumables','O2 Charges','Miscellaneous'].map(c=>`<option ${item.category===c?'selected':''}>${c}</option>`).join('')}
      </select></td>
      <td><input class="form-control" style="font-size:12px;padding:4px" value="${item.particulars}" oninput="window._billItems[${i}].particulars=this.value"></td>
      <td><input class="form-control" style="font-size:12px;padding:4px;width:80px" type="number" value="${item.rate}" oninput="window._billItems[${i}].rate=+this.value;recalcBill()"></td>
      <td><input class="form-control" style="font-size:12px;padding:4px;width:60px" type="number" value="${item.qty}" oninput="window._billItems[${i}].qty=+this.value;recalcBill()"></td>
      <td class="mono">₹${((item.rate||0)*(item.qty||1)).toLocaleString('en-IN')}</td>
      <td><button onclick="window._billItems.splice(${i},1);renderBillItems()" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:16px">×</button></td>
    </tr>
  `).join('');
  recalcBill();
}

function addBillItem() {
  window._billItems.push({ category:'Miscellaneous', particulars:'', rate:0, qty:1 });
  renderBillItems();
}

function recalcBill() {
  const gross = (window._billItems||[]).reduce((s,i)=>s+(i.rate||0)*(i.qty||1),0);
  const discount = parseFloat(document.getElementById('bill-discount')?.value)||0;
  const advance = parseFloat(document.getElementById('bill-advance')?.value)||0;
  const insurance = parseFloat(document.getElementById('bill-insurance')?.value)||0;
  const net = Math.max(0, gross - discount - advance - insurance);
  if(document.getElementById('bill-gross')) document.getElementById('bill-gross').value = '₹'+gross.toLocaleString('en-IN');
  if(document.getElementById('bill-net')) document.getElementById('bill-net').textContent = '₹'+net.toLocaleString('en-IN');
}

function generateBill(lock) {
  const pid = document.getElementById('bill-patient')?.value;
  const p = S.patients.find(x=>x.id===pid);
  if (!p) return;
  if (lock && !confirm('Lock this bill? This cannot be undone.')) return;
  if (!S.bills) S.bills = {};
  const gross = (window._billItems||[]).reduce((s,i)=>s+(i.rate||0)*(i.qty||1),0);
  const discount = parseFloat(document.getElementById('bill-discount')?.value)||0;
  const advance = parseFloat(document.getElementById('bill-advance')?.value)||0;
  const insurance = parseFloat(document.getElementById('bill-insurance')?.value)||0;
  const net = Math.max(0, gross - discount - advance - insurance);
  S.bills[pid] = {
    pid, patientName:p.name, ehrId:p.ehrId, items:[...window._billItems],
    gross, discount, advance, insurance, net,
    insName:document.getElementById('bill-ins-name')?.value,
    policy:document.getElementById('bill-policy')?.value,
    claim:document.getElementById('bill-claim')?.value,
    locked:lock, generatedAt:now(), generatedBy:getCurrentStaffName()
  };
  showToast(lock ? `Bill locked ✓ — Net payable ₹${net.toLocaleString('en-IN')}` : 'Draft bill saved');
  save();
}

function renderBillsListPage() {
  const main = document.getElementById('main');
  const bills = Object.values(S.bills||{});
  main.innerHTML = `
    <div class="section-title">Bills</div>
    <div class="section-sub">${bills.length} bill(s) generated</div>
    <div class="card">
      <table class="data-table">
        <thead><tr><th>UHID</th><th>Patient</th><th>Generated</th><th>Net (₹)</th><th>Status</th><th></th></tr></thead>
