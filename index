  document.getElementById('clock').textContent = new Date().toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:true }) + ' IST';
}
setInterval(updateClock, 1000);
updateClock();

// Vitals are entered manually by Nurse or Doctor only — no auto-simulation

