function checkAlerts(pid,v){
  const p=S.patients.find(x=>x.id===pid);
  const checks=[
    [v.bps>180,'critical','BP CRITICAL',`BP ${v.bps}/${v.bpd}`],
    [v.bps<90,'critical','HYPOTENSION',`BP ${v.bps}/${v.bpd}`],
    [v.sp<92,'critical','SpO2 CRITICAL',`SpO2 ${v.sp}%`],
    [v.sp<95,'warning','SpO2 LOW',`SpO2 ${v.sp}%`],
    [v.pr>130,'critical','TACHYCARDIA',`Pulse ${v.pr}`],
    [v.pr<50,'critical','BRADYCARDIA',`Pulse ${v.pr}`],
    [v.tmp>39.5,'critical','HIGH FEVER',`Temp ${v.tmp}°C`],
    [v.tmp>38.5,'warning','FEVER',`Temp ${v.tmp}°C`],
    [v.uo<20,'warning','OLIGURIA',`UO ${v.uo} ml/hr`],
    [v.rr>25,'warning','TACHYPNEA',`RR ${v.rr}/min`],
  ];
  checks.forEach(([cond,type,title,msg])=>{
    if(!cond) return;
    S.alerts.unshift({id:'A'+Date.now()+Math.random(),pid,type,title,msg,t:TS(),acked:false});
    showToast(`${title}: ${p?.name}`,type==='critical'?'err':'wrn');
    S.notifs.unshift({id:'N'+Date.now(),role:'Doctor',title:`⚠ ${title}`,body:`${p?.name} — ${msg}`,t:TS(),read:false});
  });
}

