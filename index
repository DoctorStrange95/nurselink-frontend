async function submitVitals(pid) {
  const bps = parseInt(document.getElementById('v-bps').value);
  const bpd = parseInt(document.getElementById('v-bpd').value);
  const pulse = parseInt(document.getElementById('v-pulse').value);
  const spo2 = parseInt(document.getElementById('v-spo2').value);
  if (!bps || !bpd || !pulse || !spo2) { alert('BP, Pulse and SpO2 are required.'); return; }
  const temp = parseFloat(document.getElementById('v-temp').value)||37.0;
  const rr = parseInt(document.getElementById('v-rr').value)||18;
  const gcs = parseInt(document.getElementById('v-gcs').value)||15;
  const uo = parseInt(document.getElementById('v-uo').value)||40;
  const glucose = parseInt(document.getElementById('v-glucose').value)||100;
  const drain = parseInt(document.getElementById('v-drain').value)||0;
  const pain = parseInt(document.getElementById('v-pain').value)||0;
  const notes = document.getElementById('v-notes').value.trim();

  const vital = { id:'V'+Date.now(), time:ts(), bpSys:bps, bpDia:bpd, pulse, spo2, temp, rr, gcs, uo, glucose, drain, pain, notes, nurse:getCurrentStaffName() };
  if (!S.vitals[pid]) S.vitals[pid] = [];
  S.vitals[pid].unshift(vital);
  checkAlerts(pid, vital);
  const p = S.patients.find(x=>x.id===pid);
  S.notifications.unshift({ id:'N'+Date.now(), role:'Doctor', title:'New Vitals', body:`${p?.name} — BP ${bps}/${bpd}, SpO2 ${spo2}%`, time:ts(), read:false });
  closeModal();

  if (IS_LIVE) {
    const res = await apiPost('/vitals/' + pid, {
      bp_sys:bps, bp_dia:bpd, pulse, spo2, temperature:temp,
      resp_rate:rr, gcs, urine_output:uo, blood_glucose:glucose,
      drain_output:drain, pain_score:pain, notes
    });
    if (res) {
      // Sync alerts from server response
      const fresh = await apiGet('/alerts');
      if (fresh) S.alerts = fresh.map(a=>({ id:String(a.id), patientId:String(a.patient_id), type:a.type, title:a.title, msg:a.message||'', time:a.created_at?new Date(a.created_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}):'', acked:!!a.acknowledged_by }));
      showToast('Vitals saved to server ✓');
    } else { showToast('Vitals saved locally — server sync failed', 'warn'); }
  } else { showToast('Vitals recorded & pushed to Doctor'); }
  showPayload({ event:'VITALS_RECORDED', patient_ehr_id:p?.ehrId, recorded_by:getCurrentStaffName(), vitals:vital });
  save();
}

